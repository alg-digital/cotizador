  renderPqList();
  renderPqCapacity();
}

function renderPqDelta() {
  const curInc  = totalMonthlyIncomeBase() * (1 + IVA);
  const curMarg = curInc - totalMonthlyPayroll(true) - totalVendorCost() - totalExpenses();
  const proInc  = projectedIncome(false);
  const proIncW = projectedIncome(true);
  const proMarg = projectedMargin(false);
  const proMargW= projectedMargin(true);
  const activeQ = getActiveQuotes();
  const extraHrs= activeQ.reduce((s,q)=>(q.assignments||[]).reduce((ss,a)=>ss+(a.hrs||0),0)+s,0);

  const fmtDelta = (v, cur) => {
    const d = v - cur;
    if (Math.abs(d) < 1) return '<span style="color:var(--ink-soft)">Sin cambio</span>';
    const sign = d > 0 ? '+' : '';
    const col  = d > 0 ? 'var(--green)' : 'var(--accent-2)';
    return `<span style="color:${col};font-weight:700">${sign}${fmt(d)}</span>`;
  };

  document.getElementById('pq-delta').innerHTML = `
    <div class="delta-card">
      <div class="delta-label">Ingresos proyectados</div>
      <div class="delta-current">${fmt(curInc)} actual</div>
      <div class="delta-arrow" style="color:#7c3aed">↓</div>
      <div class="delta-projected" style="color:#7c3aed">${fmt(proInc)}</div>
      <div class="delta-diff">${fmtDelta(proInc, curInc)}</div>
    </div>
    <div class="delta-card">
      <div class="delta-label">Ingreso ponderado (prob.)</div>
      <div class="delta-current">${fmt(curInc)} actual</div>
      <div class="delta-arrow" style="color:#0891b2">↓</div>
      <div class="delta-projected" style="color:#0891b2">${fmt(proIncW)}</div>
      <div class="delta-diff" style="font-size:.68rem;color:var(--ink-soft)">Ajustado por probabilidad</div>
    </div>
    <div class="delta-card">
      <div class="delta-label">Margen neto proyectado</div>
      <div class="delta-current">${fmt(curMarg)} actual</div>
      <div class="delta-arrow" style="color:#7c3aed">↓</div>
      <div class="delta-projected" style="color:${proMarg>=0?'var(--green)':'var(--accent-2)'}">${fmt(proMarg)}</div>
      <div class="delta-diff">${fmtDelta(proMarg, curMarg)}</div>
    </div>
    <div class="delta-card">
      <div class="delta-label">Cotizaciones activas</div>
      <div class="delta-current" style="font-size:.72rem">${activeQ.length} de ${pendingQuotes.length} seleccionadas</div>
