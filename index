      + '<td class="r" style="font-weight:600">' + fmt(total) + '</td>'
      + '<td class="r">' + (hrsA>0?hrsA.toFixed(0)+' hrs':'--') + '</td>'
      + '<td class="r">' + capPct + '</td>'
      + '</tr>';
  });
  const payTotBase = allPeople2.reduce(function(s,p){return s+(p.salary||0);},0);
  payrollRows += '<tr class="total-row"><td colspan="2">TOTAL NÓMINA</td>'
    + '<td class="r">' + fmt(payTotBase) + '</td>'
    + '<td class="r" style="color:#b45309">' + fmt(payTotBase*IVA) + '</td>'
    + '<td class="r">' + fmt(payTotBase*(1+IVA)) + '</td>'
    + '<td colspan="2"></td></tr>';

  const payrollHTML = '<div class="section-box"><table>'
    + '<thead><tr><th>Colaborador</th><th>Tipo</th><th class="r">Honorarios</th><th class="r">IVA 16%</th><th class="r">Total</th><th class="r">Hrs asig.</th><th class="r">% Cap.</th></tr></thead>'
    + '<tbody>' + payrollRows + '</tbody></table></div>';

  // ── 5. Expenses ───────────────────────────────────────
  const EXP_LABELS = {suscripcion:'Suscripción',servicios:'Servicios',renta:'Renta',varios:'Varios'};
  let expRows = '';
  expenses.forEach(function(e) {
    const total2 = expenseTotal(e);
    expRows += '<tr>'
      + '<td><span class="pill ' + (e.cat==='suscripcion'?'pill-blue':e.cat==='servicios'?'pill-gray':e.cat==='renta'?'pill-gold':'pill-gray') + '">' + (EXP_LABELS[e.cat]||e.cat) + '</span></td>'
      + '<td>' + (e.desc||'--') + '</td>'
      + '<td class="r">' + fmt(e.amount||0) + '</td>'
      + '<td style="text-align:center">' + (e.hasIva?'✓':'') + '</td>'
      + '<td class="r" style="font-weight:600">' + fmt(total2) + '</td>'
      + '<td><span class="pill ' + (e.recurrent?'pill-green':'pill-gray') + '">' + (e.recurrent?'Fijo':'Variable') + '</span></td>'
      + '</tr>';
  });
  const expCats = ['suscripcion','servicios','renta','varios'];
  expCats.forEach(function(cat) {
    const t3 = totalExpenses(cat);
    if (!t3) return;
    const lst = expenses.filter(function(e){return e.cat===cat;});
    expRows += '<tr class="sub-row"><td>' + (EXP_LABELS[cat]||cat) + '</td><td>' + lst.length + ' concepto(s)</td>'
      + '<td class="r">' + fmt(lst.reduce(function(s,e){return s+(e.amount||0);},0)) + '</td>'
      + '<td></td><td class="r">' + fmt(t3) + '</td><td></td></tr>';
  });
  expRows += '<tr class="total-row"><td colspan="4">TOTAL GASTOS OPERATIVOS</td><td class="r">' + fmt(expTotal) + '</td><td></td></tr>';

  const expHTML = expenses.length
    ? '<div class="section-box"><table>'
      + '<thead><tr><th>Categoría</th><th>Concepto</th><th class="r">Base</th><th style="text-align:center">IVA</th><th class="r">Total</th><th>Tipo</th></tr></thead>'
      + '<tbody>' + expRows + '</tbody></table></div>'
    : '<p style="font-size:10px;color:#7a7f94;padding:8px 0">Sin gastos registrados.</p>';

  // ── 6. Team capacity ──────────────────────────────────
  let capRows = '';
  employees.forEach(function(emp) {
    const hrs3   = getEmployeeAssignedHrs(emp.id);
    const pctMax = hrs3 / CAP_MAX;
    const color3 = hrs3 > CAP_MAX ? '#e8312a' : hrs3 > CAP ? '#c8972a' : '#1a3a8f';
    capRows += '<div class="cap-row">'
      + '<div><span style="font-size:10px;font-weight:600">' + emp.name + '</span>' + (emp.role ? '<span style="font-size:8.5px;color:#7a7f94;margin-left:5px">' + emp.role + '</span>' : '') + '</div>'
      + '<div style="position:relative"><div class="bar-wrap"><div class="bar-fill" style="width:' + Math.min(pctMax,1)*100 + '%;background:' + color3 + '"></div></div></div>'
      + '<div style="font-family:\'DM Mono\',monospace;font-size:9.5px;text-align:right;color:' + color3 + '">' + hrs3.toFixed(0) + '/' + CAP + 'h</div>'
      + '<div style="font-size:9px;color:#7a7f94;text-align:right">' + (hrs3/CAP*100).toFixed(0) + '%</div>'
      + '</div>';
  });
  const capHTML = '<div class="section-box" style="padding:14px 16px">'
    + '<div style="display:flex;gap:16px;margin-bottom:10px">'
    + '<div style="display:flex;align-items:center;gap:5px"><div style="width:8px;height:8px;border-radius:2px;background:#1a3a8f"></div><span style="font-size:8.5px;color:#7a7f94">≤120 hrs</span></div>'
    + '<div style="display:flex;align-items:center;gap:5px"><div style="width:8px;height:8px;border-radius:2px;background:#c8972a"></div><span style="font-size:8.5px;color:#7a7f94">121–140 hrs</span></div>'
    + '<div style="display:flex;align-items:center;gap:5px"><div style="width:8px;height:8px;border-radius:2px;background:#e8312a"></div><span style="font-size:8.5px;color:#7a7f94">>140 hrs</span></div>'
    + '</div>'
    + (capRows || '<p style="font-size:10px;color:#7a7f94">Sin colaboradores.</p>')
    + '</div>';

  // ── Assemble ──────────────────────────────────────────
  const parts = [
    '<!DOCTYPE html><html lang="es"><head><meta charset="UTF-8">',
    '<title>Reporte ALG ' + monthLabel + '</title>',
    '<style>' + CSS + '</style></head><body>',
    '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:16px;border-bottom:2px solid #0f1117">',
    '<div><div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#c8972a;margin-bottom:4px">ALG Agency</div>',
    '<h1>Reporte Mensual</h1><div style="font-size:12px;color:#7a7f94;margin-top:4px;text-transform:capitalize">' + monthLabel + '</div></div>',
    '<div style="text-align:right;font-size:9px;color:#7a7f94">',
    '<div>Documento interno — uso exclusivo dirección</div>',
    '<div style="margin-top:3px">Generado: ' + new Date().toLocaleDateString('es-MX',{day:'numeric',month:'long',year:'numeric'}) + '</div>',
    '<div style="margin-top:3px;font-family:\'DM Mono\',monospace;font-size:8px">TC: $' + getTC().toFixed(2) + ' MXN/USD</div>',
    '</div></div>',
    '<h2>1 — Resumen ejecutivo</h2>' + kpiHTML,
    '<h2>2 — Ingresos por proyecto</h2>' + incomeHTML,
    '<h2>3 — Rentabilidad por proyecto</h2>' + profitHTML,
    '<h2>4 — Nómina + IVA por colaborador</h2>' + payrollHTML,
    '<h2>5 — Gastos operativos</h2>' + expHTML,
    '<h2>6 — Carga del equipo</h2>' + capHTML,
    '<div class="footer">',
    '<span>ALG Agency · Reporte interno · ' + monthLabel + '</span>',
    '<span style="font-family:\'DM Mono\',monospace">Ingresos ' + fmt(incomeTot) + ' · Egresos ' + fmt(totalEg) + ' · Margen ' + fmt(netMargin) + ' (' + netMPct + '%)</span>',
    '</div>',
    '<scr'+'ipt>window.onload=function(){window.print();}<\/scr'+'ipt>',
    '</body></html>',
  ];
  const html = parts.join('\n');

  const w = window.open('', '_blank');
  if (!w) { showToast('Permite pop-ups para generar el reporte'); return; }
  w.document.write(html);
  w.document.close();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._t);
  t._t = setTimeout(() => t.classList.remove('show'), 2800);
}

