<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ALG — Cotizador</title>
<link href="https://api.fontshare.com/v2/css?f[]=monument-grotesk@400,500,700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink:       #0f1117;
    --ink-mid:   #3a3d4a;
    --ink-soft:  #7a7f94;
    --paper:     #f8f7f4;
    --paper-2:   #efeee9;
    --paper-3:   #e3e1d8;
    --accent:    #1a3a8f;
    --accent-2:  #e8312a;
    --gold:      #c8972a;
    --green:     #1a6b3c;
    --green-bg:  #e8f4ed;
    --red-bg:    #fdf0ef;
    --mono:      'DM Mono', monospace;
    --serif:     'Monument Grotesk', sans-serif;
    --sans:      'Monument Grotesk', sans-serif;
    --radius:    6px;
    --shadow:    0 2px 12px rgba(15,17,23,.08);
    --shadow-lg: 0 8px 40px rgba(15,17,23,.14);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 15px; }
  body {
    font-family: var(--sans);
    background: var(--paper);
    color: var(--ink);
    min-height: 100vh;
  }

  /* ── HEADER ── */
  header {
    background: var(--ink);
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    position: sticky; top: 0; z-index: 100;
  }
  .logo { font-family: var(--sans); font-weight: 700; font-size: 1.4rem; color: #fff; letter-spacing: .02em; }
  .logo span { color: var(--gold); }
  header nav { display: flex; gap: 6px; }
  header nav button {
    background: transparent; border: 1px solid rgba(255,255,255,.15);
    color: rgba(255,255,255,.7); padding: 6px 16px; border-radius: 30px;
    font-family: var(--sans); font-size: .8rem; cursor: pointer;
    transition: all .2s;
  }
  header nav button.active, header nav button:hover {
    background: rgba(255,255,255,.1); color: #fff; border-color: rgba(255,255,255,.4);
  }

  /* ── LAYOUT ── */
  .app { display: grid; grid-template-columns: 1fr 360px; min-height: calc(100vh - 60px); }
  .main { padding: 32px 40px; overflow-y: auto; }
  .sidebar {
    background: var(--ink); color: #fff;
    padding: 28px 24px;
    display: flex; flex-direction: column; gap: 0;
    position: sticky; top: 60px; height: calc(100vh - 60px);
    overflow-y: auto;
  }

  /* ── SECTIONS ── */
  .section { margin-bottom: 32px; }
  .section-title {
    font-family: var(--sans); font-weight: 700; font-size: 1.25rem; color: var(--ink);
    margin-bottom: 16px; padding-bottom: 8px;
    border-bottom: 2px solid var(--ink);
    display: flex; align-items: center; gap: 10px;
  }
  .section-title .num {
    font-family: var(--mono); font-size: .7rem; color: var(--paper);
    background: var(--ink); padding: 2px 8px; border-radius: 20px;
  }

  /* ── CLIENT INFO ── */
  .client-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .field-group { display: flex; flex-direction: column; gap: 4px; }
  .field-group label { font-size: .75rem; font-weight: 600; color: var(--ink-soft); text-transform: uppercase; letter-spacing: .06em; }
  .field-group input, .field-group select {
    border: 1.5px solid var(--paper-3);
    background: #fff; border-radius: var(--radius);
    padding: 9px 12px; font-family: var(--sans); font-size: .9rem; color: var(--ink);
    transition: border-color .15s;
    appearance: none; -webkit-appearance: none;
  }
  .field-group input:focus, .field-group select:focus { outline: none; border-color: var(--accent); }

  /* ── PARAMS BAR ── */
  .params-bar {
    background: var(--ink); color: #fff;
    padding: 14px 20px; border-radius: var(--radius);
    display: flex; gap: 28px; align-items: center;
    margin-bottom: 24px; flex-wrap: wrap;
  }
  .param-item { display: flex; flex-direction: column; gap: 3px; }
  .param-item label { font-size: .65rem; text-transform: uppercase; letter-spacing: .08em; color: rgba(255,255,255,.5); }
  .param-item input {
    background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.2);
    color: #fff; font-family: var(--mono); font-size: .85rem;
    padding: 4px 8px; border-radius: 4px; width: 90px;
    transition: border-color .15s;
  }
  .param-item input:focus { outline: none; border-color: rgba(255,255,255,.6); }

  /* ── SERVICES ── */
  .services-list { display: flex; flex-direction: column; gap: 16px; }
  .service-card {
    background: #fff; border: 1.5px solid var(--paper-3);
    border-radius: 8px; overflow: hidden;
    box-shadow: var(--shadow); transition: box-shadow .2s;
  }
  .service-card:hover { box-shadow: var(--shadow-lg); }

  .service-header {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 18px; cursor: pointer;
    background: var(--paper-2); border-bottom: 1.5px solid var(--paper-3);
    user-select: none;
  }
  .service-header:hover { background: var(--paper-3); }
  .service-toggle {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--ink); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: .7rem; flex-shrink: 0; transition: transform .2s;
  }
  .service-card.open .service-toggle { transform: rotate(45deg); background: var(--accent-2); }
  .service-name-input {
    flex: 1; background: transparent; border: none;
    font-family: var(--sans); font-weight: 700; font-size: 1rem; color: var(--ink);
    cursor: text;
  }
  .service-name-input:focus { outline: none; }
  .service-price-tag {
    font-family: var(--mono); font-size: .8rem; color: var(--ink-soft);
    background: var(--paper-3); padding: 3px 10px; border-radius: 20px;
    white-space: nowrap;
  }
  .service-price-tag.has-value { background: var(--green-bg); color: var(--green); font-weight: 500; }

  .service-body { display: none; padding: 0; }
  .service-card.open .service-body { display: block; }

  /* ── PHASE ── */
  .phase-block { border-bottom: 1px solid var(--paper-2); }
  .phase-header {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 18px; background: rgba(26,58,143,.04);
    border-bottom: 1px solid var(--paper-2);
  }
  .phase-tag {
    font-family: var(--mono); font-size: .7rem; color: var(--accent);
    background: rgba(26,58,143,.1); padding: 2px 8px; border-radius: 4px;
  }
  .phase-name-input {
    flex: 1; border: none; background: transparent;
    font-weight: 600; font-size: .85rem; color: var(--ink);
    font-family: var(--sans);
  }
  .phase-name-input:focus { outline: none; }
  .btn-del-phase {
    background: none; border: none; color: var(--ink-soft);
    cursor: pointer; font-size: .8rem; padding: 2px 6px;
    border-radius: 4px; transition: all .15s;
  }
  .btn-del-phase:hover { background: var(--red-bg); color: var(--accent-2); }

  /* ── ACTIVITY ROWS ── */
  .activities-table { width: 100%; }
  .act-row {
    display: grid;
    grid-template-columns: 1fr 160px 72px 36px;
    gap: 0;
    border-bottom: 1px solid var(--paper-2);
    transition: background .1s;
  }
  .act-row:hover { background: var(--paper); }
  .act-row > * { padding: 8px 10px; border-right: 1px solid var(--paper-2); }
  .act-row > *:last-child { border-right: none; }

  .act-desc {
    border: none; background: transparent;
    font-family: var(--sans); font-size: .85rem; color: var(--ink);
    resize: none; min-height: 34px; width: 100%;
  }
  .act-desc:focus { outline: none; }
  .act-select {
    border: none; background: transparent;
    font-size: .8rem; color: var(--ink-mid); width: 100%;
    appearance: none; -webkit-appearance: none; cursor: pointer;
    font-family: var(--sans);
  }
  .act-select:focus { outline: none; }
  .act-hrs {
    border: none; background: transparent;
    font-family: var(--mono); font-size: .85rem; color: var(--ink);
    text-align: right; width: 100%;
  }
  .act-hrs:focus { outline: none; }
  .btn-del-act {
    background: none; border: none; color: var(--paper-3);
    cursor: pointer; font-size: .9rem; display: flex;
    align-items: center; justify-content: center;
    transition: color .15s;
  }
  .btn-del-act:hover { color: var(--accent-2); }

  .act-header-row {
    display: grid;
    grid-template-columns: 1fr 160px 72px 36px;
    background: var(--paper-2);
    border-bottom: 1px solid var(--paper-3);
  }
  .act-header-row span {
    padding: 5px 10px; font-size: .65rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em; color: var(--ink-soft);
    border-right: 1px solid var(--paper-3);
  }
  .act-header-row span:last-child { border-right: none; }

  .phase-footer {
    display: flex; gap: 8px; padding: 8px 14px;
    background: rgba(26,58,143,.02);
  }
  .btn-add-act {
    font-size: .75rem; color: var(--accent); background: rgba(26,58,143,.06);
    border: 1px dashed rgba(26,58,143,.3); border-radius: 4px;
    padding: 4px 12px; cursor: pointer; font-family: var(--sans);
    transition: all .15s;
  }
  .btn-add-act:hover { background: rgba(26,58,143,.12); }

  .service-footer {
    display: flex; gap: 10px; padding: 12px 18px;
    border-top: 1px solid var(--paper-2); background: var(--paper);
    flex-wrap: wrap; align-items: center;
  }
  .btn-add-phase {
    font-size: .8rem; color: var(--accent); background: transparent;
    border: 1.5px dashed rgba(26,58,143,.4); border-radius: 6px;
    padding: 7px 16px; cursor: pointer; font-family: var(--sans);
    transition: all .15s; display: flex; align-items: center; gap: 6px;
  }
  .btn-add-phase:hover { background: rgba(26,58,143,.06); }
  .btn-del-service {
    margin-left: auto; font-size: .75rem; color: var(--ink-soft);
    background: transparent; border: 1px solid var(--paper-3);
    border-radius: 4px; padding: 6px 12px; cursor: pointer; font-family: var(--sans);
    transition: all .15s;
  }
  .btn-del-service:hover { border-color: var(--accent-2); color: var(--accent-2); }

  .btn-add-service {
    display: flex; align-items: center; gap: 10px;
    border: 2px dashed var(--paper-3); border-radius: 8px;
    padding: 16px 20px; color: var(--ink-soft);
    background: transparent; cursor: pointer; font-family: var(--sans);
    font-size: .9rem; transition: all .2s; width: 100%;
    margin-top: 4px;
  }
  .btn-add-service:hover { border-color: var(--accent); color: var(--accent); background: rgba(26,58,143,.03); }

  /* ── SIDEBAR ── */
  .sidebar-title {
    font-family: var(--sans); font-weight: 700; font-size: 1.1rem; color: #fff;
    margin-bottom: 20px; padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,.1);
  }

  .summary-block { margin-bottom: 20px; }
  .summary-block-title {
    font-size: .65rem; text-transform: uppercase; letter-spacing: .1em;
    color: rgba(255,255,255,.4); margin-bottom: 10px;
  }
  .summary-line {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,.06);
  }
  .summary-line .lbl { font-size: .8rem; color: rgba(255,255,255,.65); }
  .summary-line .val { font-family: var(--mono); font-size: .85rem; color: #fff; }
  .summary-line.total .lbl { font-weight: 700; color: #fff; font-size: .9rem; }
  .summary-line.total .val { font-size: 1rem; color: var(--gold); }
  .summary-line.subtl .lbl { color: rgba(255,255,255,.4); font-size: .75rem; }
  .summary-line.subtl .val { font-size: .78rem; color: rgba(255,255,255,.5); }

  .service-summary-item {
    padding: 8px 10px; border-radius: 6px;
    background: rgba(255,255,255,.05); margin-bottom: 6px;
  }
  .ssi-name { font-size: .8rem; color: rgba(255,255,255,.8); margin-bottom: 4px; }
  .ssi-row { display: flex; justify-content: space-between; }
  .ssi-hrs { font-size: .72rem; color: rgba(255,255,255,.4); font-family: var(--mono); }
  .ssi-price { font-size: .82rem; color: var(--gold); font-family: var(--mono); }

  /* Params in sidebar */
  .sidebar-params { margin-bottom: 20px; }
  .sp-row { display: flex; gap: 8px; margin-bottom: 8px; }
  .sp-item { flex: 1; }
  .sp-item label { font-size: .65rem; color: rgba(255,255,255,.4); display: block; margin-bottom: 3px; text-transform: uppercase; letter-spacing: .06em; }
  .sp-item input {
    width: 100%; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.15);
    color: #fff; font-family: var(--mono); font-size: .85rem;
    padding: 6px 8px; border-radius: 4px;
  }
  .sp-item input:focus { outline: none; border-color: var(--gold); }

  /* discount & payment */
  .dcto-row { display: flex; gap: 8px; align-items: center; margin: 10px 0; }
  .dcto-row label { font-size: .75rem; color: rgba(255,255,255,.6); flex: 1; }
  .dcto-row input {
    width: 70px; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.15);
    color: #fff; font-family: var(--mono); font-size: .85rem;
    padding: 5px 8px; border-radius: 4px; text-align: right;
  }
  .dcto-row input:focus { outline: none; border-color: var(--gold); }

  .final-price-box {
    background: var(--gold); color: var(--ink);
    border-radius: 8px; padding: 16px;
    margin: 16px 0; text-align: center;
  }
  .fpb-label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; opacity: .7; }
  .fpb-val { font-family: var(--sans); font-weight: 700; font-size: 1.8rem; margin: 4px 0; }
  .fpb-sub { font-size: .72rem; opacity: .65; }

  /* Payment plan */
  .payment-plan { margin-top: 12px; }
  .pp-title { font-size: .65rem; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.4); margin-bottom: 8px; }
  .pp-options { display: flex; gap: 6px; margin-bottom: 10px; }
  .pp-btn {
    flex: 1; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.15);
    color: rgba(255,255,255,.6); padding: 6px 4px; border-radius: 4px;
    font-size: .72rem; cursor: pointer; font-family: var(--sans); transition: all .15s;
    text-align: center;
  }
  .pp-btn.active { background: rgba(200,151,42,.2); border-color: var(--gold); color: var(--gold); }
  .pp-result {
    background: rgba(255,255,255,.05); border-radius: 6px;
    padding: 12px; display: flex; flex-direction: column; gap: 6px;
  }
  .pp-item { display: flex; justify-content: space-between; }
  .pp-item .k { font-size: .75rem; color: rgba(255,255,255,.5); }
  .pp-item .v { font-family: var(--mono); font-size: .8rem; color: #fff; }

  /* Team breakdown */
  .team-breakdown { margin-top: 16px; }
  .tb-title { font-size: .65rem; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.4); margin-bottom: 8px; }
  .tb-row { display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,.05); }
  .tb-name { font-size: .78rem; color: rgba(255,255,255,.7); }
  .tb-hrs { font-family: var(--mono); font-size: .75rem; color: rgba(255,255,255,.45); }

  /* Export button */
  .btn-export {
    width: 100%; margin-top: 16px;
    background: #fff; color: var(--ink); border: none;
    padding: 12px; border-radius: 6px; font-family: var(--sans);
    font-size: .85rem; font-weight: 700; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: all .2s;
  }
  .btn-export:hover { background: var(--gold); }

  /* ── PRINT / PDF ── */
  @media print {
    header, .sidebar { display: none !important; }
    .app { display: block; }
    .main { padding: 20px; }
    .service-body { display: block !important; }
  }

  /* ── UTIL ── */
  .mono { font-family: var(--mono); }
  .tag {
    display: inline-block; font-size: .7rem; padding: 2px 8px;
    border-radius: 20px; font-weight: 600;
  }
  .tag.green { background: var(--green-bg); color: var(--green); }
  .tag.red { background: var(--red-bg); color: var(--accent-2); }

  select option { font-family: var(--sans); }

  input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }

  /* ── SPECIAL BLOCKS ── */
  .special-block { border-top: 2px solid var(--paper-2); }
  .special-header {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    padding: 9px 18px; background: var(--paper);
    border-bottom: 1px solid var(--paper-2);
  }
  .special-tag {
    font-size: .68rem; font-weight: 700; padding: 3px 10px;
    border-radius: 20px; letter-spacing: .04em; white-space: nowrap;
  }
  .juntas-tag  { background: #e8f0fe; color: #1a3a8f; }
  .outsrc-tag  { background: #fff3e0; color: #b45309; }
  .special-label { font-size: .85rem; font-weight: 600; color: var(--ink); }
  .special-note  { font-size: .72rem; color: var(--ink-soft); margin-left: auto; font-style: italic; }

  .special-fixed-cell {
    padding: 8px 10px; font-size: .8rem; color: var(--ink-soft);
    border-right: 1px solid var(--paper-2); display: flex; align-items: center;
  }

  .outsrc-row { grid-template-columns: 1fr 180px 110px 36px !important; }
  .outsrc-row-hdr { grid-template-columns: 1fr 180px 110px 36px !important; }
  .outsrc-field {
    display: flex; flex-direction: column; justify-content: center;
    padding: 4px 10px; border-right: 1px solid var(--paper-2); gap: 2px;
  }
  .outsrc-label { font-size: .65rem; color: var(--ink-soft); }

  .btn-special {
    font-size: .75rem; padding: 6px 12px; border-radius: 4px;
    cursor: pointer; font-family: var(--sans); transition: all .15s;
    border: 1px dashed; background: transparent;
  }
  .juntas-btn  { color: #1a3a8f; border-color: rgba(26,58,143,.35); }
  .juntas-btn:hover  { background: rgba(26,58,143,.07); }
  .outsrc-btn  { color: #b45309; border-color: rgba(180,83,9,.35); }
  .outsrc-btn:hover  { background: rgba(180,83,9,.07); }

  /* ── TEMPLATES ── */
  .tmpl-filter {
    font-size:.78rem; padding:6px 14px; border-radius:20px;
    border: 1.5px solid var(--paper-3); background:transparent;
    cursor:pointer; font-family:var(--sans); transition:all .15s; color:var(--ink-mid);
  }
  .tmpl-filter:hover  { border-color:var(--accent); color:var(--accent); }
  .tmpl-filter.active { background:var(--accent); color:#fff; border-color:var(--accent); }

  .tmpl-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:16px; }

  .tmpl-card {
    background:#fff; border:1.5px solid var(--paper-3); border-radius:10px;
    padding:18px 20px; box-shadow:var(--shadow);
    display:flex; flex-direction:column; gap:10px;
    transition: box-shadow .2s, transform .15s;
  }
  .tmpl-card:hover { box-shadow:var(--shadow-lg); transform:translateY(-2px); }

  .tmpl-card-top { display:flex; align-items:flex-start; justify-content:space-between; gap:8px; }
  .tmpl-card-name { font-weight:700; font-size:.95rem; color:var(--ink); }
  .tmpl-level-badge {
    font-size:.65rem; font-weight:700; padding:3px 9px; border-radius:20px;
    white-space:nowrap; flex-shrink:0;
  }
  .level-startup   { background:#e8f5e9; color:#2e7d32; }
  .level-mediana   { background:#e3f2fd; color:#1565c0; }
  .level-enterprise{ background:#fce4ec; color:#880e4f; }

  .tmpl-meta { font-size:.75rem; color:var(--ink-soft); }
  .tmpl-notes { font-size:.78rem; color:var(--ink-mid); font-style:italic; }

  .tmpl-phases { display:flex; flex-wrap:wrap; gap:4px; }
  .tmpl-phase-tag {
    font-size:.68rem; background:rgba(26,58,143,.07); color:var(--accent);
    padding:2px 8px; border-radius:4px; font-family:var(--mono);
  }

  .tmpl-actions { display:flex; gap:8px; margin-top:4px; }
  .tmpl-btn-load {
    flex:1; padding:7px 12px; background:var(--accent); color:#fff;
    border:none; border-radius:6px; cursor:pointer; font-family:var(--sans);
    font-size:.78rem; font-weight:600; transition:background .15s;
  }
  .tmpl-btn-load:hover { background:#1530a0; }
  .tmpl-btn-del {
    padding:7px 10px; background:transparent; color:var(--ink-soft);
    border:1.5px solid var(--paper-3); border-radius:6px; cursor:pointer;
    font-size:.78rem; transition:all .15s;
  }
  .tmpl-btn-del:hover { border-color:var(--accent-2); color:var(--accent-2); }

  /* ── Subtle fade-in */
  /* Subtle fade-in */
  @keyframes fadeUp { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
  .service-card { animation: fadeUp .25s ease both; }
</style>
</head>
<body>

<header>
  <div class="logo">ALG <span>·</span> Cotizador</div>
  <nav>
    <button class="active" onclick="showTab('builder')">Constructor</button>
    <button onclick="showTab('breakdown')">Desglose</button>
    <button onclick="showTab('templates')">📁 Templates</button>
