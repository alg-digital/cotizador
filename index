// PAYMENT PLAN
// ══════════════════════════════════════════════════════
function setPP(n) {
  ppMonths = n;
  document.querySelectorAll('.pp-btn').forEach(b => b.classList.remove('active'));
  const ids = {1:'pp1',2:'pp2',3:'pp3',6:'pp6',12:'pp12'};
  if (ids[n]) document.getElementById(ids[n]).classList.add('active');
  const params = getParams();
  const tot = calcTotal(params);
  refreshPaymentPlan(tot.precioFinal);
}

function refreshPaymentPlan(precioFinal) {
  const discRow = document.getElementById('pp-disc-row');
  const DISC_UNICO = 0.05;
  if (ppMonths === 1) {
    const withDisc = precioFinal * (1 - DISC_UNICO);
    document.getElementById('pp-total').textContent = fmt(withDisc);
    document.getElementById('pp-n').textContent = '1';
    document.getElementById('pp-disc').textContent = fmt(precioFinal * DISC_UNICO);
    document.getElementById('pp-monto').textContent = fmt(withDisc);
    discRow.style.display = '';
  } else {
    document.getElementById('pp-total').textContent = fmt(precioFinal);
    document.getElementById('pp-n').textContent = ppMonths;
    discRow.style.display = 'none';
    document.getElementById('pp-monto').textContent = fmt(precioFinal / ppMonths);
  }
}

