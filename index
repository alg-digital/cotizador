}

function deleteExpense(id) {
  expenses = expenses.filter(e => e.id !== id);
  renderExpensesPage();
  renderDashboard();
  if (SUPABASE_READY) sbDelete('alg_expenses', id);
}

function updateExpense(id, field, value) {
  const exp = expenses.find(e => e.id === id);
  if (!exp) return;
  if (field === 'cat')       exp.cat      = value;
  if (field === 'desc')      exp.desc     = value;
  if (field === 'amount')    exp.amount   = parseFloat(value) || 0;
  if (field === 'hasIva')    exp.hasIva   = value;
  if (field === 'recurrent') exp.recurrent= value;
  renderExpensesPage();
  renderDashboard();
  if (SUPABASE_READY) {
    clearTimeout(window._expSyncTimer);
    window._expSyncTimer = setTimeout(() => {
      const e = expenses.find(x=>x.id===id);
      if (e) sbSave('alg_expenses', e);
    }, 1200);
  }
}

function filterExpenses(cat, btn) {
  _expFilter = cat;
  document.querySelectorAll('#exp-cat-tabs button').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderExpensesTable();
}

function renderExpensesTable() {
  const tbody  = document.getElementById('exp-tbody');
  const tfoot  = document.getElementById('exp-tfoot');
  const empty  = document.getElementById('exp-empty');
  const table  = document.getElementById('exp-table');
  const count  = document.getElementById('exp-count');

  const filtered = _expFilter === 'all' ? expenses : expenses.filter(e => e.cat === _expFilter);
  count.textContent = expenses.length ? `(${expenses.length})` : '';

  if (!expenses.length) {
    table.style.display = 'none'; empty.style.display = 'block';
    return;
  }
  table.style.display = ''; empty.style.display = 'none';

  tbody.innerHTML = filtered.map(exp => {
    const total  = expenseTotal(exp);
    const catObj = EXP_CATS.find(c => c.value === exp.cat) || EXP_CATS[3];
    return `<tr>
      <td>
        <select class="exp-select" onchange="updateExpense(${exp.id},'cat',this.value)">
          ${EXP_CATS.map(c => `<option value="${c.value}" ${c.value===exp.cat?'selected':''}>${c.label}</option>`).join('')}
        </select>
      </td>
      <td><input class="exp-input" type="text" value="${exp.desc||''}" placeholder="Ej. Adobe CC, Fibra óptica…"
        oninput="updateExpense(${exp.id},'desc',this.value)"></td>
      <td style="text-align:right">
        <input class="exp-num" type="number" value="${exp.amount||''}" placeholder="0" min="0" step="100"
          oninput="updateExpense(${exp.id},'amount',this.value)">
      </td>
      <td style="text-align:center">
        <input type="checkbox" ${exp.hasIva?'checked':''} style="cursor:pointer;width:16px;height:16px"
          onchange="updateExpense(${exp.id},'hasIva',this.checked)">
      </td>
      <td style="text-align:right;font-family:var(--mono);font-size:.82rem;font-weight:600">
        ${fmt(total)}
        ${exp.hasIva ? `<div style="font-size:.65rem;color:var(--amber);font-weight:400">+IVA ${fmt(total - exp.amount)}</div>` : ''}
      </td>
      <td style="text-align:center">
        <input type="checkbox" ${exp.recurrent?'checked':''} style="cursor:pointer;width:16px;height:16px"
          onchange="updateExpense(${exp.id},'recurrent',this.checked)"
          title="Gasto recurrente mensual">
      </td>
      <td><button class="btn-del-row" onclick="deleteExpense(${exp.id})">×</button></td>
    </tr>`;
  }).join('');

  // Footer totals
  const totalBase  = filtered.reduce((s,e) => s + (e.amount||0), 0);
  const totalIva   = filtered.reduce((s,e) => s + (e.hasIva ? (e.amount||0)*IVA : 0), 0);
  const totalFinal = totalBase + totalIva;
  const totalFixed = filtered.filter(e=>e.recurrent).reduce((s,e)=>s+expenseTotal(e),0);
  const totalVar   = totalFinal - totalFixed;

  tfoot.innerHTML = `
    <tr style="border-top:2px solid var(--ink)">
      <td colspan="2" style="padding:8px 12px;font-weight:700;font-size:.84rem">TOTAL${_expFilter!=='all'?' (filtrado)':''}</td>
      <td style="text-align:right;padding:8px 10px;font-family:var(--mono);font-size:.8rem;color:var(--ink-soft)">${fmt(totalBase)}</td>
      <td style="text-align:center;padding:8px 10px;font-family:var(--mono);font-size:.75rem;color:var(--amber)">+${fmt(totalIva)}</td>
      <td style="text-align:right;padding:8px 10px;font-family:var(--mono);font-size:.9rem;font-weight:700">${fmt(totalFinal)}</td>
      <td style="text-align:center;padding:8px 10px">
        <div style="font-size:.65rem;color:var(--ink-soft)">Fijo: <strong>${fmt(totalFixed)}</strong></div>
        <div style="font-size:.65rem;color:var(--ink-soft)">Var: <strong>${fmt(totalVar)}</strong></div>
      </td>
      <td></td>
    </tr>`;
}

function renderExpensesSummary() {
  const card = document.getElementById('exp-summary-card');
  const body = document.getElementById('exp-summary-body');
  if (!expenses.length) { card.style.display='none'; return; }
  card.style.display = 'block';

  const rows = EXP_CATS.map(cat => {
    const list = expenses.filter(e => e.cat === cat.value);
    if (!list.length) return '';
    const total   = list.reduce((s,e)=>s+expenseTotal(e),0);
