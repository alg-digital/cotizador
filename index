const SUPABASE_URL  = 'https://njocteicmmscpinfcgxc.supabase.co';
const SUPABASE_KEY  = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5qb2N0ZWljbW1zY3BpbmZjZ3hjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ1OTExNDcsImV4cCI6MjA5MDE2NzE0N30.IuR17io-7_9jMkqJS3puFfhiAebwb1lTqvOt91RtcU0';

// Supabase REST helper
async function sbFetch(table, method='GET', body=null, filters='') {
  const url = `${SUPABASE_URL}/rest/v1/${table}${filters}`;
  const opts = {
    method,
    headers: {
      'Content-Type':  'application/json',
      'apikey':         SUPABASE_KEY,
      'Authorization': `Bearer ${SUPABASE_KEY}`,
      'Prefer':        'return=representation',
    },
  };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(url, opts);
  if (!res.ok) {
    const err = await res.text();
    throw new Error(`Supabase ${method} ${table}: ${err}`);
  }
  // DELETE, PATCH without return=representation, and empty responses have no body
  if (method === 'DELETE' || method === 'PATCH') return null;
  const text = await res.text();
  if (!text || text.trim() === '') return null;
  return JSON.parse(text);
}

// ── LOAD ALL DATA FROM SUPABASE ─────────────────────
async function loadFromSupabase() {
  showSyncStatus('syncing');
  try {
    const [emps, corps, projs, vends, exps] = await Promise.all([
      sbFetch('alg_employees'),
      sbFetch('alg_corporates'),
      sbFetch('alg_projects'),
      sbFetch('alg_vendors'),
      sbFetch('alg_expenses'),
    ]);

    // Supabase returns rows with { id, data, is_combined? }
    // Spread data fields and override with the real Supabase id
    const mapRow = (r) => ({ ...(r.data || {}), id: r.id });
    employees  = (emps  ||[]).map(mapRow);
    corporates = (corps ||[]).map(r => ({ ...(r.data||{}), id: r.id, _combined: !!r.is_combined }));
    projects   = (projs ||[]).map(mapRow);
    vendors    = (vends ||[]).map(mapRow);
    expenses   = (exps  ||[]).map(mapRow);

    // Keep local idCounter well above Supabase's max to avoid collisions
    const allIds = [
      ...(emps||[]), ...(corps||[]), ...(projs||[]), ...(vends||[]), ...(exps||[])
    ].map(r => r.id).filter(n => typeof n === 'number');
    const maxSbId = allIds.length ? Math.max(...allIds) : 0;
    idCounter = Math.max(idCounter, maxSbId + 1, 1000000);

    renderAll();
    showSyncStatus('ok');
  } catch(e) {
    console.error('Supabase load error:', e);
    showSyncStatus('error', e.message);
    renderAll(); // render with empty data anyway
  }
}

// ── SAVE HELPERS ────────────────────────────────────
// Strategy: render locally immediately (fast UX), then sync to Supabase
// in the background. On reload, Supabase is the source of truth.

function stripLocalFields(record) {
  // Remove runtime-only fields that shouldn't be stored
  const { _open, _showBd, _fromCotizador, _fromCot, _cat } = record;
  const clean = { ...record };
  delete clean._open; delete clean._showBd;
  delete clean._fromCotizador; delete clean._fromCot; delete clean._cat;
  return clean;
}

async function sbSave(table, record) {
  const clean = stripLocalFields(record);
  const { id, ...data } = clean;
  try {
    showSyncStatus('syncing');
    const isNew = !id || (typeof id === 'number' && id >= 1000000);
    if (isNew) {
      const res = await sbFetch(table, 'POST', { data });
      // Update the record's id with Supabase-generated id
      if (res && res[0] && res[0].id) {
        record.id = res[0].id;
      }
    } else {
      await sbFetch(table, 'PATCH', { data }, `?id=eq.${id}`);
    }
    showSyncStatus('ok');
  } catch(e) {
    console.error('sbSave error:', e);
    showSyncStatus('error', e.message);
  }
}

async function sbUpsert(table, record) {
  return sbSave(table, record);
}

async function sbDelete(table, id) {
  try {
    showSyncStatus('syncing');
    await sbFetch(table, 'DELETE', null, `?id=eq.${id}`);
    showSyncStatus('ok');
  } catch(e) {
    console.error('sbDelete error:', e);
    showSyncStatus('error', e.message);
  }
}

// Sync status indicator
function showSyncStatus(state, msg='') {
  const el = document.getElementById('sync-status');
  if (!el) return;
  const states = {
    syncing: { icon:'⟳', color:'rgba(255,255,255,.5)', text:'Sincronizando…' },
    ok:      { icon:'✓', color:'#4ade80',              text:'Guardado'       },
    error:   { icon:'✕', color:'#f87171',              text:'Error: '+msg    },
    offline: { icon:'◌', color:'rgba(255,255,255,.3)', text:'Sin Supabase'   },
  };
  const s = states[state] || states.offline;
  el.innerHTML = `<span style="color:${s.color};font-size:.72rem;font-family:var(--mono)">${s.icon} ${s.text}</span>`;
}

// Check if Supabase is configured
const SUPABASE_READY = SUPABASE_URL !== 'TU_SUPABASE_URL';

// ── COLORS ─────────────────────────────
const COLORS = ['#1a3a8f','#c8972a','#e8312a','#1a6b3c','#b45309','#6d28d9','#0e7490','#9d174d'];
let colorIdx = 0;

// ── STATE ──────────────────────────────
let employees   = []; // { id, name, role, salary }
let corporates  = []; // { id, name, role, salary }
let projects    = []; // { id, name, client, type, income, total, color, assignments:[{empId,pct}] }
let vendors     = []; // { id, name, projectId, cost, charge }
let expenses    = []; // { id, cat, desc, amount, hasIva, recurrent }
let _expFilter  = 'all';
let pendingQuotes = []; // { id, name, client, income, prob, assignments:[{empId,hrs}], scenA, scenB, _fromCot }
let _activeScenario = 'A'; // 'A' | 'B' | 'all'
let _projPanelOpen  = false;
let _pqAssignRows   = [];

// Local temp IDs start at 1,000,000 so they never collide with
// Supabase bigserial IDs (which start at 1 and grow slowly).
// After sbSave, Supabase IDs replace local ones via loadFromSupabase().
let idCounter = 1000000;
const uid = () => idCounter++;

// Edit mode
let editingProjectId = null;

// ── MONTH ──────────────────────────────
const mInput = document.getElementById('active-month');
const now = new Date();
mInput.value = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;

// ── FORMAT ─────────────────────────────
const fmt    = n => '$' + Math.round(n).toLocaleString('es-MX');
const fmtUSD = n => 'USD $' + n.toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0});
const fmtPct = n => (n*100).toFixed(0) + '%';
const getTC  = () => parseFloat(document.getElementById('tc-usd')?.value) || 17.90;

// Convert project income to MXN (if stored in USD)
function incomeInMXN(proj) {
  if (proj.currency === 'USD') return (proj.income || 0) * getTC();
  return proj.income || 0;
}

// ── CONSTANTS ──────────────────────────
const CAP      = 120;  // horas efectivas al mes
const CAP_MAX  = 140;  // límite con margen de mejora (+20)
const IVA      = 0.16; // IVA aplicado a honorarios

// Horas por colaborador: producción + juntas si están en el bloque de juntas
function getEmployeeAssignedHrs(empId) {
  let hrs = 0;
  projects.forEach(p => {
    // Producción
    const a = (p.assignments||[]).find(x => x.empId === empId);
    if (a) hrs += (a.hrs || 0);
    // Juntas: si el empleado está en la lista de afectados
    if (p.juntas && p.juntas.hrs > 0 && (p.juntas.members||[]).includes(empId)) {
      // Distribuir hrs de junta equitativamente entre los miembros afectados
      const n = (p.juntas.members||[]).length;
      if (n > 0) hrs += p.juntas.hrs / n;
    }
  });
  return hrs;
}

function getProjectHrs(proj) {
  const prodHrs   = (proj.assignments||[]).reduce((s,a) => s + (a.hrs||0), 0);
  const juntasHrs = proj.juntas?.hrs || 0;
  return prodHrs + juntasHrs;
}

function totalMonthlyPayroll(withIva=false) {
  const mult = withIva ? (1 + IVA) : 1;
  // Combinados ya están en employees — excluirlos de corporates para no duplicar
  const corpOnly = corporates.filter(c => !c._combined);
  return (
    employees.reduce((s,e)  => s + (e.salary||0), 0) +
    corpOnly.reduce((s,c)   => s + (c.salary||0), 0)
  ) * mult;
}

function getEmployeeCostIva(emp) {
  return (emp.salary||0) * IVA;
}

// ── TARIFA JUNTAS** ────────────────────────────────────────
// Sueldo fijo $30,000 / 120 hrs = $250/hr (igual que el Cotizador)
const JUNTAS_RATE    = 30000 / 120;  // $250/hr
const OVERHEAD_RATE  = 1.5;
const UTIL_RATE      = 0.5;

// Costo real de una hora según tipo y tarifa
// Formula Cotizador: costoDir = hrs×rate, overhead = costoDir×1.5
// costoTotal = costoDir + overhead, precioLleno = costoTotal / (1-0.5)
function calcHrCost(hrs, rate) {
  const costoDir   = hrs * rate;
  const overhead   = costoDir * OVERHEAD_RATE;
  const costoTotal = costoDir + overhead;
  return { costoDir, overhead, costoTotal,
           precioLleno: costoTotal / (1 - UTIL_RATE) };
}

// Costo de equipo asignado (producción únicamente, sin IVA)
function getProjectTeamCost(proj) {
  const prodCost = (proj.assignments||[]).reduce((s, a) => {
    const emp = employees.find(e => e.id === a.empId);
    if (!emp) return s;
    const empRate = (emp.salary || 0) / CAP;
    if (a.breakdown && a.breakdown.length > 0) {
      return s + a.breakdown.reduce((bs, b) => {
        return bs + calcHrCost(b.hrs || 0, empRate).costoTotal;
      }, 0);
    }
    return s + calcHrCost(a.hrs || 0, empRate).costoTotal;
  }, 0);

  // Juntas: bloque separado del proyecto con tarifa JUNTAS**
  const juntasCost = proj.juntas && proj.juntas.hrs > 0
    ? calcHrCost(proj.juntas.hrs, JUNTAS_RATE).costoTotal
    : 0;

  return prodCost + juntasCost;
}

function totalMonthlyIncome() {
  // Ingresos de proyectos: en MXN + IVA cobrado al cliente
  const projIncome   = projects.reduce((s,p) => s + incomeInMXN(p) * (1 + IVA), 0);
  // Proveedores: solo el margen (cobro - costo), ya incluye IVA si aplica
  const vendorMargin = vendors.reduce((s,v) => s + ((v.charge||0) - (v.cost||0)), 0);
  return projIncome + vendorMargin;
}

// Ingreso base sin IVA (para mostrar en algunos contextos)
function totalMonthlyIncomeBase() {
  return projects.reduce((s,p) => s + incomeInMXN(p), 0);
}

// A vendor is "active this month" if:
//  activeMode === 'yes'  → always active
//  activeMode === 'no'   → always inactive
//  activeMode === 'auto' (default) → active if linked to an active project
function isVendorActive(v) {
  if (v.activeMode === 'no')  return false;
  if (v.activeMode === 'yes') return true;
  // auto: active if its project exists
  return !!projects.find(p => p.id === v.projectId);
}

function totalVendorCost() {
  return vendors.filter(isVendorActive).reduce((s,v) => s + (v.cost||0), 0);
}

function expenseTotal(exp) {
  const base = exp.amount || 0;
  return exp.hasIva ? base * (1 + IVA) : base;
}

function totalExpenses(cat='all') {
  return expenses
    .filter(e => cat === 'all' || e.cat === cat)
    .reduce((s, e) => s + expenseTotal(e), 0);
}

// ── CAPACITY STATUS (base = CAP_MAX 140 hrs) ────────
// Verde  : 0 – 120 hrs  (zona efectiva)
// Ámbar  : 121 – 140 hrs (margen de mejora)
// Rojo   : > 140 hrs     (sobrecargado)
function capStatus(hrs) {
  if (hrs === 0)        return { cls:'idle', label:'Sin asignar' };
  if (hrs <= CAP)       return { cls:'ok',   label:'OK' };
  if (hrs <= CAP_MAX)   return { cls:'warn',  label:'En margen' };
  return                       { cls:'over',  label:'Sobrecargado' };
}

// ── DONUT SVG ───────────────────────────
function miniRing(pct, color) {
  const r = 16, c = 21, circ = 2 * Math.PI * r;
  const filled = Math.min(pct, 1) * circ;
  const overflow = pct > 1 ? (pct - 1) * circ : 0;
  return `<div class="mini-ring">
    <svg viewBox="0 0 42 42">
      <circle class="track" cx="${c}" cy="${c}" r="${r}"/>
      <circle class="fill" cx="${c}" cy="${c}" r="${r}"
        stroke="${color||'var(--accent)'}"
        stroke-dasharray="${circ}"
        stroke-dashoffset="${circ - filled}"/>
      ${overflow > 0 ? `<circle class="fill" cx="${c}" cy="${c}" r="${r}"
        stroke="var(--accent-2)"
        stroke-dasharray="${circ}"
        stroke-dashoffset="${circ - overflow}"/>` : ''}
    </svg>
  </div>`;
}

// ── DASHBOARD ──────────────────────────
function renderDashboard() {
  renderKPIs();
