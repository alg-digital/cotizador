<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ALG — Dashboard de Capacidad</title>
<link href="https://api.fontshare.com/v2/css?f[]=monument-grotesk@400,500,700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink:       #0f1117;
  --ink-mid:   #3a3d4a;
  --ink-soft:  #7a7f94;
  --paper:     #f8f7f4;
  --paper-2:   #efeee9;
  --paper-3:   #e3e1d8;
  --accent:    #1a3a8f;
  --accent-2:  #e8312a;
  --gold:      #c8972a;
  --green:     #1a6b3c;
  --green-bg:  #e8f4ed;
  --red-bg:    #fdf0ef;
  --amber:     #b45309;
  --amber-bg:  #fff8f0;
  --mono:      'DM Mono', monospace;
  --sans:      'Monument Grotesk', sans-serif;
  --radius:    6px;
  --shadow:    0 2px 12px rgba(15,17,23,.08);
  --shadow-lg: 0 8px 40px rgba(15,17,23,.14);
  --cap:       120; /* horas efectivas al mes */
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 15px; }
body { font-family: var(--sans); background: var(--paper); color: var(--ink); min-height: 100vh; }

/* ── HEADER ── */
header {
  background: var(--ink); padding: 0 40px;
  display: flex; align-items: center; justify-content: space-between;
  height: 60px; position: sticky; top: 0; z-index: 100;
}
.logo { font-weight: 700; font-size: 1.4rem; color: #fff; letter-spacing: .02em; }
.logo span { color: var(--gold); }
header nav { display: flex; gap: 6px; }
header nav button {
  background: transparent; border: 1px solid rgba(255,255,255,.15);
  color: rgba(255,255,255,.7); padding: 6px 16px; border-radius: 30px;
  font-family: var(--sans); font-size: .8rem; cursor: pointer; transition: all .2s;
}
header nav button.active, header nav button:hover {
  background: rgba(255,255,255,.1); color: #fff; border-color: rgba(255,255,255,.4);
}
.header-month {
  display: flex; align-items: center; gap: 10px;
}
.header-month label { font-size: .72rem; color: rgba(255,255,255,.45); text-transform: uppercase; letter-spacing: .06em; }
.header-month input {
  background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.2);
  color: #fff; font-family: var(--mono); font-size: .82rem;
  padding: 5px 10px; border-radius: 4px;
}
.header-month input:focus { outline: none; border-color: var(--gold); }

/* ── PAGE WRAPPER ── */
.page { display: none; }
.page.active { display: block; }

/* ── DASHBOARD ── */
.dash-wrap { padding: 32px 40px; max-width: 1280px; margin: 0 auto; }

/* KPI CARDS */
.kpi-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 32px; }
.kpi-card {
  background: #fff; border: 1.5px solid var(--paper-3); border-radius: 10px;
  padding: 20px 22px; box-shadow: var(--shadow);
  display: flex; flex-direction: column; gap: 8px;
}
.kpi-label { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-soft); }
.kpi-val { font-family: var(--mono); font-size: 1.7rem; font-weight: 500; color: var(--ink); line-height: 1; }
.kpi-val.green { color: var(--green); }
.kpi-val.gold  { color: var(--gold); }
.kpi-val.red   { color: var(--accent-2); }
.kpi-sub { font-size: .72rem; color: var(--ink-soft); }
.kpi-bar { height: 4px; background: var(--paper-3); border-radius: 2px; margin-top: 4px; overflow: hidden; }
.kpi-bar-fill { height: 100%; border-radius: 2px; transition: width .4s ease; }

/* TWO-COL */
.two-col { display: grid; grid-template-columns: 1fr 340px; gap: 24px; margin-bottom: 32px; }
.three-col { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; margin-bottom: 32px; }

/* CARD */
.card {
  background: #fff; border: 1.5px solid var(--paper-3); border-radius: 10px;
  box-shadow: var(--shadow); overflow: hidden;
}
.card-header {
  padding: 14px 20px; border-bottom: 1.5px solid var(--paper-2);
  display: flex; align-items: center; justify-content: space-between;
  background: var(--paper-2);
}
.card-title { font-weight: 700; font-size: .9rem; color: var(--ink); }
.card-body { padding: 16px 20px; }

/* CAPACITY BARS */
.cap-row {
  display: flex; align-items: center; gap: 12px;
  padding: 9px 0; border-bottom: 1px solid var(--paper-2);
}
.cap-row:last-child { border-bottom: none; }
.cap-name { font-size: .82rem; font-weight: 600; color: var(--ink); min-width: 100px; flex-shrink: 0; }
.cap-bar-wrap { flex: 1; height: 8px; background: var(--paper-3); border-radius: 4px; overflow: visible; position: relative; }
.cap-bar-fill { height: 100%; border-radius: 4px; transition: width .4s ease; position: relative; }
.cap-bar-overflow {
  position: absolute; right: 0; top: 0; height: 100%; border-radius: 0 4px 4px 0;
  background: var(--accent-2); opacity: .85;
}
.cap-pct { font-family: var(--mono); font-size: .75rem; min-width: 42px; text-align: right; flex-shrink: 0; }
.cap-hrs { font-family: var(--mono); font-size: .72rem; color: var(--ink-soft); min-width: 58px; text-align: right; flex-shrink: 0; }
.dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

/* STATUS BADGE */
.badge {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: .68rem; font-weight: 700; padding: 3px 9px; border-radius: 20px;
  letter-spacing: .03em;
}
.badge.ok     { background: var(--green-bg); color: var(--green); }
.badge.warn   { background: var(--amber-bg); color: var(--amber); }
.badge.over   { background: var(--red-bg); color: var(--accent-2); }
.badge.idle   { background: var(--paper-2); color: var(--ink-soft); }
.badge.fixed  { background: rgba(26,58,143,.1); color: var(--accent); }
.badge.oneshot{ background: rgba(200,151,42,.12); color: var(--gold); }

/* PROJECT TABLE */
.proj-table { width: 100%; border-collapse: collapse; }
.proj-table th {
  font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
  color: var(--ink-soft); padding: 7px 12px; text-align: left;
  background: var(--paper-2); border-bottom: 1.5px solid var(--paper-3);
}
.proj-table th.r { text-align: right; }
.proj-table td { padding: 9px 12px; border-bottom: 1px solid var(--paper-2); font-size: .84rem; vertical-align: middle; }
.proj-table td.r { text-align: right; font-family: var(--mono); font-size: .8rem; }
.proj-table tr:last-child td { border-bottom: none; }
.proj-table tr:hover td { background: var(--paper); }

/* INCOME BAR */
.income-bar-wrap { display: flex; align-items: center; gap: 8px; }
.income-bar-bg { flex: 1; height: 6px; background: var(--paper-3); border-radius: 3px; overflow: hidden; min-width: 60px; }
.income-bar-fill { height: 100%; border-radius: 3px; background: var(--green); transition: width .4s; }

/* ── SECTIONS SHARED ── */
.section-wrap { padding: 32px 40px; max-width: 1280px; margin: 0 auto; }
.section-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24px; flex-wrap: wrap; gap: 12px;
}
.section-title { font-weight: 700; font-size: 1.4rem; color: var(--ink); }
.section-title small { font-size: .75rem; color: var(--ink-soft); font-weight: 400; margin-left: 10px; }

/* FORM MODAL */
.modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(15,17,23,.55); z-index: 999;
  align-items: center; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal {
  background: #fff; border-radius: 12px; padding: 32px;
  width: 520px; max-width: 94vw; max-height: 90vh; overflow-y: auto;
  box-shadow: 0 24px 80px rgba(15,17,23,.25);
  animation: modalIn .2s ease;
}
@keyframes modalIn { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:none; } }
.modal h3 { font-weight: 700; font-size: 1.05rem; margin-bottom: 22px; }

.field-group { display: flex; flex-direction: column; gap: 4px; margin-bottom: 14px; }
.field-group label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--ink-soft); }
.field-group input, .field-group select, .field-group textarea {
  border: 1.5px solid var(--paper-3); background: #fff; border-radius: var(--radius);
  padding: 9px 12px; font-family: var(--sans); font-size: .9rem; color: var(--ink);
  transition: border-color .15s; appearance: none;
}
.field-group input:focus, .field-group select:focus, .field-group textarea:focus {
  outline: none; border-color: var(--accent);
}
.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

.modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; }
.btn-cancel {
  padding: 9px 20px; border: 1.5px solid var(--paper-3); border-radius: 6px;
  background: transparent; cursor: pointer; font-family: var(--sans); font-size: .85rem;
}
.btn-save {
  padding: 9px 22px; background: var(--accent); color: #fff; border: none;
  border-radius: 6px; cursor: pointer; font-family: var(--sans);
  font-size: .85rem; font-weight: 700; transition: background .15s;
}
.btn-save:hover { background: #1530a0; }

/* BTN ADD */
.btn-add {
  display: inline-flex; align-items: center; gap: 7px;
  background: var(--ink); color: #fff; border: none; border-radius: 6px;
  padding: 9px 18px; font-family: var(--sans); font-size: .82rem; font-weight: 700;
  cursor: pointer; transition: all .2s;
}
.btn-add:hover { background: var(--accent); }
.btn-add.outline {
  background: transparent; color: var(--ink); border: 1.5px solid var(--paper-3);
}
.btn-add.outline:hover { border-color: var(--accent); color: var(--accent); background: rgba(26,58,143,.04); }

/* ASSIGNMENT ROWS in project detail */
.assign-list { display: flex; flex-direction: column; gap: 6px; }
.assign-row {
  display: grid; grid-template-columns: 1fr 80px 90px 36px;
  gap: 0; align-items: center;
  border: 1.5px solid var(--paper-3); border-radius: 6px; overflow: hidden;
}
.assign-row > * { padding: 7px 10px; border-right: 1px solid var(--paper-2); }
.assign-row > *:last-child { border-right: none; }
.assign-select {
  border: none; background: transparent; font-family: var(--sans);
  font-size: .84rem; color: var(--ink); width: 100%; appearance: none; cursor: pointer;
}
.assign-select:focus { outline: none; }
.assign-input {
  border: none; background: transparent; font-family: var(--mono);
  font-size: .84rem; color: var(--ink); width: 100%; text-align: right;
}
.assign-input:focus { outline: none; }
.assign-hrs-cell { font-family: var(--mono); font-size: .75rem; color: var(--ink-soft); padding: 7px 10px; border-right: 1px solid var(--paper-2); text-align: right; }
.btn-del-row {
  background: none; border: none; color: var(--paper-3); cursor: pointer;
  font-size: .9rem; display: flex; align-items: center; justify-content: center;
  transition: color .15s; width: 36px; height: 100%;
}
.btn-del-row:hover { color: var(--accent-2); }

/* BIG LIST ── projects, employees, vendors */
.list-grid { display: flex; flex-direction: column; gap: 12px; }
.list-card {
  background: #fff; border: 1.5px solid var(--paper-3); border-radius: 10px;
  box-shadow: var(--shadow); overflow: hidden;
  animation: fadeUp .22s ease both;
}
@keyframes fadeUp { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }
.list-card-header {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 20px; background: var(--paper-2);
  border-bottom: 1.5px solid var(--paper-3); cursor: pointer;
}
.list-card-header:hover { background: var(--paper-3); }
.list-card-name { font-weight: 700; font-size: .95rem; flex: 1; }
.list-card-body { display: none; padding: 20px; }
.list-card.open .list-card-body { display: block; }
.toggle-icon {
  width: 22px; height: 22px; border-radius: 50%;
  background: var(--ink); color: #fff; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: .7rem; transition: transform .2s;
}
.list-card.open .toggle-icon { transform: rotate(45deg); background: var(--accent-2); }

/* EMPTY STATE */
.empty-state {
  text-align: center; padding: 60px 20px; color: var(--ink-soft);
}
.empty-state .icon { font-size: 2.5rem; margin-bottom: 12px; }
.empty-state p { font-size: .88rem; }

/* CORPORATE TABLE */
.corp-table { width: 100%; border-collapse: collapse; }
.corp-table th {
  font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
  color: var(--ink-soft); padding: 7px 14px; text-align: left;
  background: var(--paper-2); border-bottom: 1.5px solid var(--paper-3);
}
.corp-table th.r { text-align: right; }
.corp-table td { padding: 10px 14px; border-bottom: 1px solid var(--paper-2); font-size: .84rem; vertical-align: middle; }
.corp-table td.r { text-align: right; font-family: var(--mono); font-size: .8rem; }
.corp-table tr:last-child td { border-bottom: none; }
.corp-table tr:hover td { background: var(--paper); }
.corp-input {
  border: none; background: transparent; font-family: var(--sans);
  font-size: .84rem; color: var(--ink); width: 100%;
}
.corp-input-mono {
  border: none; background: transparent; font-family: var(--mono);
  font-size: .82rem; color: var(--ink); width: 80px; text-align: right;
}
.corp-input-mono:focus, .corp-input:focus { outline: none; }

/* VENDOR CARDS */
.vendor-row {
  display: grid; grid-template-columns: 1fr 120px 120px 120px 36px;
  gap: 0; align-items: center;
  border: 1.5px solid var(--paper-3); border-radius: 8px;
  overflow: hidden; margin-bottom: 10px; background: #fff;
}
.vendor-row > * { padding: 10px 12px; border-right: 1px solid var(--paper-2); font-size: .84rem; }
.vendor-row > *:last-child { border-right: none; }
.vendor-input {
  border: none; background: transparent; font-family: var(--sans);
  font-size: .84rem; color: var(--ink); width: 100%;
}
.vendor-input:focus { outline: none; }
.vendor-num {
  border: none; background: transparent; font-family: var(--mono);
  font-size: .82rem; color: var(--ink); width: 100%; text-align: right;
}
.vendor-num:focus { outline: none; }
.vendor-header {
  display: grid; grid-template-columns: 1fr 120px 120px 120px 36px;
  background: var(--paper-2); border-radius: 6px 6px 0 0;
  border: 1.5px solid var(--paper-3); border-bottom: none;
}
.vendor-header span {
  font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
  color: var(--ink-soft); padding: 6px 12px; border-right: 1px solid var(--paper-3);
}
.vendor-header span:last-child { border-right: none; }

/* BREAKDOWN ROWS inside assign */
.breakdown-list { margin-top:4px; padding:4px 0 4px 12px; border-left:2px solid var(--paper-3); }
.bd-row {
  display:grid; grid-template-columns:1fr 70px 24px;
  gap:0; align-items:center; padding:3px 0;
}
.bd-input {
  border:none; background:transparent; font-family:var(--sans);
  font-size:.78rem; color:var(--ink); width:100%;
}
.bd-input:focus { outline:none; }
.bd-hrs {
  border:none; background:transparent; font-family:var(--mono);
  font-size:.78rem; color:var(--ink); width:100%; text-align:right;
}
.bd-hrs:focus { outline:none; }
.btn-del-bd {
  background:none; border:none; color:var(--paper-3); cursor:pointer;
  font-size:.8rem; display:flex; align-items:center; justify-content:center;
  transition:color .15s;
}
.btn-del-bd:hover { color:var(--accent-2); }
.toggle-bd {
  font-size:.7rem; color:var(--accent); background:rgba(26,58,143,.07);
  border:1px solid rgba(26,58,143,.2); border-radius:4px;
  padding:2px 8px; cursor:pointer; font-family:var(--sans);
  transition:all .15s; white-space:nowrap;
}
.toggle-bd:hover { background:rgba(26,58,143,.14); }

/* TOAST */
#toast {
  position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px);
  background: var(--ink); color: #fff; padding: 10px 22px; border-radius: 30px;
  font-size: .84rem; opacity: 0; transition: all .25s; z-index: 9999;
  pointer-events: none; white-space: nowrap;
}
#toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* MINI DONUT — pure CSS */
.mini-ring { position: relative; width: 42px; height: 42px; flex-shrink: 0; }
.mini-ring svg { width: 42px; height: 42px; transform: rotate(-90deg); }
.mini-ring .track { fill: none; stroke: var(--paper-3); stroke-width: 5; }
.mini-ring .fill  { fill: none; stroke-width: 5; stroke-linecap: round; transition: stroke-dashoffset .4s ease; }

/* FINANCIAL SUMMARY PANEL */
.fin-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:0; }
.fin-cell { padding:18px 22px; border-right:1px solid var(--paper-3); }
.fin-cell:last-child { border-right:none; }
.fin-label { font-size:.62rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--ink-soft); margin-bottom:6px; }
.fin-val { font-family:var(--mono); font-size:1.4rem; font-weight:500; line-height:1; }
.fin-sub { font-size:.72rem; color:var(--ink-soft); margin-top:5px; }
.fin-divider { height:1px; background:var(--paper-3); }

/* PAYROLL BREAKDOWN TABLE */
.payroll-row { display:flex; justify-content:space-between; align-items:center; padding:7px 0; border-bottom:1px solid var(--paper-2); }
.payroll-row:last-child { border-bottom:none; }
.payroll-name { font-size:.82rem; color:var(--ink-mid); }
.payroll-base { font-family:var(--mono); font-size:.78rem; color:var(--ink-soft); }
.payroll-iva  { font-family:var(--mono); font-size:.72rem; color:var(--amber); }
.payroll-total{ font-family:var(--mono); font-size:.82rem; font-weight:600; color:var(--ink); }

/* PROFITABILITY BARS */
.profit-row { margin-bottom:14px; }
.profit-name { display:flex; justify-content:space-between; align-items:center; margin-bottom:5px; }
.profit-bar-wrap { position:relative; height:8px; background:var(--paper-3); border-radius:4px; overflow:hidden; }
.profit-bar-income { position:absolute; left:0; top:0; height:100%; background:var(--green); border-radius:4px; transition:width .4s; }
.profit-bar-cost   { position:absolute; left:0; top:0; height:100%; background:var(--accent-2); opacity:.55; border-radius:4px; transition:width .4s; }

/* EDIT EMPLOYEE MODAL */
.edit-emp-modal { width:460px; }

/* EXPENSES TABLE */
.exp-table { width:100%; border-collapse:collapse; }
.exp-table th {
  font-size:.65rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em;
  color:var(--ink-soft); padding:7px 12px; text-align:left;
  background:var(--paper-2); border-bottom:1.5px solid var(--paper-3);
}
.exp-table th.r { text-align:right; }
.exp-table td { padding:6px 10px; border-bottom:1px solid var(--paper-2); vertical-align:middle; }
.exp-table tr:last-child td { border-bottom:none; }
.exp-table tr:hover td { background:var(--paper); }
.exp-input {
  border:none; background:transparent; font-family:var(--sans);
  font-size:.84rem; color:var(--ink); width:100%;
}
.exp-input:focus { outline:none; }
.exp-num {
  border:none; background:transparent; font-family:var(--mono);
  font-size:.82rem; color:var(--ink); width:90px; text-align:right;
}
.exp-num:focus { outline:none; }
.exp-select {
  border:none; background:transparent; font-family:var(--sans);
  font-size:.82rem; color:var(--ink); cursor:pointer; appearance:none;
}
.exp-select:focus { outline:none; }
.cat-pill {
  display:inline-block; font-size:.68rem; font-weight:700; padding:2px 9px;
  border-radius:20px; letter-spacing:.03em;
}
.cat-suscripcion { background:#e8f0fe; color:#1a3a8f; }
.cat-servicios   { background:#f3e8ff; color:#6d28d9; }
.cat-renta       { background:#fef9c3; color:#854d0e; }
.cat-varios      { background:var(--paper-2); color:var(--ink-soft); }

/* PROJECTION PANEL */
.proj-panel { border:2px solid rgba(139,92,246,.3); border-radius:10px; overflow:hidden; margin-bottom:32px; }
.proj-panel-header {
  display:flex; align-items:center; gap:12px; padding:14px 20px;
  background:linear-gradient(135deg,rgba(139,92,246,.08),rgba(99,102,241,.05));
  cursor:pointer; user-select:none; border-bottom:1px solid rgba(139,92,246,.15);
}
.proj-panel-header:hover { background:linear-gradient(135deg,rgba(139,92,246,.13),rgba(99,102,241,.08)); }
.proj-panel-title { font-weight:700; font-size:.95rem; color:#5b21b6; flex:1; }
.proj-panel-body { display:none; padding:20px; }
.proj-panel.open .proj-panel-body { display:block; }
.proj-panel-chevron { font-size:.8rem; color:#7c3aed; transition:transform .25s; }
.proj-panel.open .proj-panel-chevron { transform:rotate(180deg); }

/* Pending quote card */
.pq-card {
  border:1.5px solid var(--paper-3); border-radius:8px; overflow:hidden;
  margin-bottom:10px; background:#fff;
}
.pq-header {
  display:grid; grid-template-columns:auto 1fr auto auto auto auto;
  gap:0; align-items:center;
}
.pq-toggle-a, .pq-toggle-b {
  width:28px; height:28px; border-radius:50%; border:2px solid;
  display:flex; align-items:center; justify-content:center;
  font-size:.65rem; font-weight:800; cursor:pointer;
  transition:all .15s; flex-shrink:0; font-family:var(--mono);
}
.pq-toggle-a { border-color:#7c3aed; color:#7c3aed; background:transparent; }
.pq-toggle-a.on { background:#7c3aed; color:#fff; }
.pq-toggle-b { border-color:#0891b2; color:#0891b2; background:transparent; }
.pq-toggle-b.on { background:#0891b2; color:#fff; }

/* Delta KPI */
.delta-row { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:16px; }
.delta-card { background:#fff; border:1.5px solid var(--paper-3); border-radius:8px; padding:14px 16px; }
.delta-label { font-size:.62rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:var(--ink-soft); margin-bottom:6px; }
.delta-current { font-family:var(--mono); font-size:.85rem; color:var(--ink-soft); }
.delta-arrow { font-size:.75rem; margin:3px 0; }
.delta-projected { font-family:var(--mono); font-size:1.1rem; font-weight:600; }
.delta-diff { font-size:.72rem; font-weight:700; margin-top:3px; }

/* Ghost capacity bar */
.ghost-bar { position:absolute; left:0; top:0; height:100%; border-radius:5px;
             opacity:.35; transition:width .4s; pointer-events:none; }

/* Scenario tabs */
.scen-tab {
  padding:5px 14px; border-radius:20px; font-size:.75rem; font-weight:700;
  cursor:pointer; border:2px solid; transition:all .15s; font-family:var(--sans);
}
.scen-a { border-color:#7c3aed; color:#7c3aed; background:transparent; }
.scen-a.on { background:#7c3aed; color:#fff; }
.scen-b { border-color:#0891b2; color:#0891b2; background:transparent; }
.scen-b.on { background:#0891b2; color:#fff; }

/* UTIL */
.mono { font-family: var(--mono); }
input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }
select { cursor: pointer; }
.separator { height: 1px; background: var(--paper-3); margin: 16px 0; }
.text-right { text-align: right; }
.gap-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
</style>
</head>
<body>

<!-- ══════════ HEADER ══════════ -->
<header>
  <div class="logo">ALG <span>·</span> Capacidad</div>
  <div id="sync-status" style="margin-left:12px"></div>
  <nav>
    <button class="active" onclick="showPage('dashboard')">Dashboard</button>
    <button onclick="showPage('projects')">Proyectos</button>
    <button onclick="showPage('employees')">Equipo</button>
    <button onclick="showPage('vendors')">Proveedores</button>
    <button onclick="showPage('expenses')">Gastos</button>
  </nav>
  <div class="header-month">
    <label>Mes activo</label>
    <input type="month" id="active-month">
  </div>
  <div class="header-month" style="margin-left:16px;padding-left:16px;border-left:1px solid rgba(255,255,255,.15)">
    <label style="color:rgba(255,255,255,.45);font-size:.65rem;text-transform:uppercase;letter-spacing:.06em">Importar cotización</label>
    <label style="cursor:pointer;display:flex;align-items:center;gap:6px;background:#1a6b3c;color:#fff;padding:5px 12px;border-radius:4px;font-size:.78rem;font-weight:600;font-family:var(--sans)">
      📥 .json
      <input type="file" accept=".json" onchange="importCotizacion(event)" style="display:none">
    </label>
  </div>
  <div class="header-month" style="margin-left:16px;padding-left:16px;border-left:1px solid rgba(255,255,255,.15)">
    <button onclick="exportMonthlyReport()" style="
      background:var(--gold);color:var(--ink);border:none;padding:6px 14px;
      border-radius:4px;font-family:var(--sans);font-size:.78rem;font-weight:700;
      cursor:pointer;display:flex;align-items:center;gap:6px;transition:opacity .2s"
      onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
      📊 Reporte del mes
    </button>
  </div>
  <div class="header-month" style="margin-left:16px;padding-left:16px;border-left:1px solid rgba(255,255,255,.15)">
    <label>TC USD → MXN</label>
    <input type="number" id="tc-usd" value="17.90" step="0.05" min="1"
      style="width:80px" oninput="renderAll()" title="Tipo de cambio USD a MXN">
  </div>
</header>

<!-- ══════════ DASHBOARD ══════════ -->
<div class="page active" id="page-dashboard">
<div class="dash-wrap">

  <!-- KPIs -->
  <div class="kpi-row" id="kpi-row"></div>

  <!-- Capacity + Project table -->
  <div class="two-col">
    <!-- Capacity -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Carga del equipo</span>
        <span style="font-size:.72rem;color:var(--ink-soft)">120 hrs efectivas / mes</span>
      </div>
      <div class="card-body" id="capacity-panel" style="padding:12px 20px"></div>
    </div>

    <!-- Project income -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Ingresos por proyecto</span>
      </div>
      <div class="card-body" id="income-panel" style="padding:12px 20px"></div>
    </div>
  </div>

  <!-- Financial Summary -->
  <div class="card" style="margin-bottom:24px">
    <div class="card-header">
      <span class="card-title">Resumen financiero del mes</span>
      <span style="font-size:.72rem;color:var(--ink-soft)">Honorarios + IVA 16%</span>
    </div>
    <div id="fin-summary"></div>
  </div>

  <!-- Profitability + Payroll breakdown -->
  <div class="two-col" style="margin-bottom:24px">
    <div class="card">
      <div class="card-header">
        <span class="card-title">Rentabilidad por proyecto</span>
        <span style="font-size:.72rem;color:var(--ink-soft)">Ingreso vs costo de equipo</span>
      </div>
      <div class="card-body" id="profitability-panel" style="padding:16px 20px"></div>
    </div>
    <div class="card">
      <div class="card-header">
        <span class="card-title">Desglose nómina + IVA</span>
        <span style="font-size:.72rem;color:var(--ink-soft)">Por colaborador</span>
      </div>
      <div class="card-body" id="payroll-panel" style="padding:12px 20px"></div>
    </div>
  </div>

  <!-- 🔮 Projection Panel -->
  <div class="proj-panel" id="proj-panel">
    <div class="proj-panel-header" onclick="toggleProjPanel()">
      <span style="font-size:1.1rem">🔮</span>
      <span class="proj-panel-title">Proyecciones — Cotizaciones pendientes</span>
      <label style="cursor:pointer;display:flex;align-items:center;gap:6px;background:rgba(124,58,237,.1);color:#7c3aed;padding:5px 12px;border-radius:4px;font-size:.75rem;font-weight:700;font-family:var(--sans)" onclick="event.stopPropagation()">
        📥 Importar cotización
        <input type="file" accept=".json" onchange="importPendingQuote(event)" style="display:none">
      </label>
      <button onclick="event.stopPropagation();openAddPendingQuote()" style="background:rgba(124,58,237,.1);color:#7c3aed;border:none;padding:5px 12px;border-radius:4px;font-size:.75rem;font-weight:700;font-family:var(--sans);cursor:pointer;margin-left:6px">＋ Manual</button>
      <span id="pq-count-badge" style="font-size:.72rem;color:rgba(124,58,237,.6);margin-left:8px"></span>
      <span class="proj-panel-chevron">▼</span>
    </div>
    <div class="proj-panel-body">

      <!-- Empty state -->
      <div id="pq-empty" style="text-align:center;padding:32px 20px;color:var(--ink-soft)">
        <div style="font-size:2rem;margin-bottom:10px">📋</div>
        <div style="font-weight:600;margin-bottom:4px">Sin cotizaciones pendientes</div>
        <div style="font-size:.82rem">Importa un JSON del Cotizador o agrégalas manualmente.</div>
      </div>

      <!-- Scenarios comparison toggle -->
      <div id="pq-scen-bar" style="display:none;margin-bottom:16px">
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
          <span style="font-size:.75rem;font-weight:700;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.05em">Ver escenario:</span>
          <button class="scen-tab scen-a on" id="scen-tab-a" onclick="setActiveScenario('A')">A — Selección A</button>
          <button class="scen-tab scen-b" id="scen-tab-b" onclick="setActiveScenario('B')">B — Selección B</button>
          <button class="scen-tab" id="scen-tab-all" onclick="setActiveScenario('all')" style="border-color:var(--ink-soft);color:var(--ink-soft)">Todas</button>
          <span style="font-size:.72rem;color:var(--ink-soft);margin-left:auto">Marca A/B en cada cotización para comparar escenarios</span>
        </div>
      </div>

      <!-- Delta KPIs -->
      <div id="pq-delta" style="display:none" class="delta-row"></div>

      <!-- Pending quotes list -->
      <div id="pq-list" style="display:none"></div>

      <!-- Projected capacity -->
      <div id="pq-capacity" style="display:none">
        <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin:16px 0 10px">Carga del equipo proyectada</div>
        <div id="pq-capacity-bars"></div>
      </div>
    </div>
  </div>

  <!-- Alerts -->
  <div class="card" id="alerts-card" style="margin-bottom:32px">
    <div class="card-header">
      <span class="card-title">⚠️ Alertas operativas</span>
    </div>
    <div class="card-body" id="alerts-panel" style="padding:14px 20px"></div>
  </div>

</div>
</div>

<!-- ══════════ PROJECTS ══════════ -->
<div class="page" id="page-projects">
<div class="section-wrap">
  <div class="section-head">
    <div>
      <div class="section-title">Proyectos <small id="proj-count"></small></div>
    </div>
    <button class="btn-add" onclick="openModal('project')">＋ Nuevo proyecto</button>
  </div>
  <div class="list-grid" id="projects-list"></div>
  <div class="empty-state" id="proj-empty" style="display:none">
    <div class="icon">📋</div>
    <p>No hay proyectos aún. Crea el primero.</p>
  </div>
</div>
</div>

<!-- ══════════ EMPLOYEES ══════════ -->
<div class="page" id="page-employees">
<div class="section-wrap">
  <div class="section-head">
    <div>
      <div class="section-title">Equipo <small id="emp-count"></small></div>
    </div>
    <button class="btn-add" onclick="openModal('employee')">＋ Agregar colaborador</button>
  </div>

  <!-- Billable team -->
  <div class="card" style="margin-bottom:24px">
    <div class="card-header">
      <span class="card-title">Colaboradores facturables</span>
      <span style="font-size:.72rem;color:var(--ink-soft)">Asignados a proyectos por % de sus 120 hrs</span>
    </div>
    <div style="overflow-x:auto">
      <table class="corp-table" id="emp-table">
        <thead>
          <tr>
            <th>Nombre</th>
            <th class="r">Honorarios/mes</th>
            <th class="r">Hrs asignadas</th>
            <th class="r">% Ocupación</th>
            <th>Estado</th>
            <th class="r">Con IVA</th>
            <th style="width:60px"></th>
          </tr>
        </thead>
        <tbody id="emp-tbody"></tbody>
      </table>
    </div>
    <div class="empty-state" id="emp-empty" style="display:none;padding:30px 20px">
      <p>Sin colaboradores. Agrega el primero.</p>
    </div>
  </div>

  <!-- Corporate (non-billable) -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">Empleados corporativos</span>
      <button class="btn-add outline" style="font-size:.78rem;padding:6px 14px" onclick="openModal('corporate')">＋ Agregar</button>
    </div>
    <div style="overflow-x:auto">
      <table class="corp-table" id="corp-table">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Rol</th>
            <th class="r">Honorarios</th>
            <th class="r">Con IVA</th>
            <th style="width:60px"></th>
          </tr>
        </thead>
        <tbody id="corp-tbody"></tbody>
      </table>
    </div>
    <div class="empty-state" id="corp-empty" style="display:none;padding:30px 20px">
      <p>Sin empleados corporativos.</p>
    </div>
  </div>
</div>
</div>

<!-- ══════════ VENDORS ══════════ -->
<div class="page" id="page-vendors">
<div class="section-wrap">
  <div class="section-head">
    <div>
      <div class="section-title">Proveedores <small id="vendor-count"></small></div>
    </div>
    <button class="btn-add" onclick="openModal('vendor')">＋ Agregar proveedor</button>
  </div>

  <!-- Active filter -->
  <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap" id="vendor-filters">
    <button class="tmpl-filter active" onclick="filterVendors('all',this)">Todos</button>
    <button class="tmpl-filter" onclick="filterVendors('active',this)">✅ Activos este mes</button>
    <button class="tmpl-filter" onclick="filterVendors('inactive',this)">⏸ Inactivos</button>
  </div>

  <div class="list-grid" id="vendors-list"></div>

  <div class="empty-state" id="vendor-empty">
    <div class="icon">📦</div>
    <p>No hay proveedores registrados.</p>
  </div>

  <!-- Vendor summary -->
  <div class="card" id="vendor-summary-card" style="display:none;margin-top:24px">
    <div class="card-header"><span class="card-title">Resumen de proveedores</span></div>
    <div class="card-body" id="vendor-summary-body"></div>
  </div>
</div>
</div>

<!-- ══════════ GASTOS ══════════ -->
<div class="page" id="page-expenses">
<div class="section-wrap">
  <div class="section-head">
    <div>
      <div class="section-title">Gastos operativos <small id="exp-count"></small></div>
    </div>
    <button class="btn-add" onclick="addExpenseRow()">＋ Agregar gasto</button>
  </div>

  <!-- Category tabs -->
  <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap" id="exp-cat-tabs">
    <button class="tmpl-filter active" onclick="filterExpenses('all',this)">Todos</button>
    <button class="tmpl-filter" onclick="filterExpenses('suscripcion',this)">🔵 Suscripciones</button>
    <button class="tmpl-filter" onclick="filterExpenses('servicios',this)">🟣 Servicios</button>
    <button class="tmpl-filter" onclick="filterExpenses('renta',this)">🟡 Renta</button>
    <button class="tmpl-filter" onclick="filterExpenses('varios',this)">⚪ Varios</button>
  </div>

  <div class="card" style="margin-bottom:24px">
    <div style="overflow-x:auto">
      <table class="exp-table" id="exp-table">
        <thead>
          <tr>
            <th style="width:140px">Categoría</th>
            <th>Concepto</th>
            <th class="r" style="width:120px">Monto base</th>
            <th style="width:70px;text-align:center">IVA</th>
            <th class="r" style="width:120px">Total</th>
            <th style="width:90px;text-align:center">Recurrente</th>
            <th style="width:36px"></th>
          </tr>
        </thead>
        <tbody id="exp-tbody"></tbody>
        <tfoot id="exp-tfoot"></tfoot>
      </table>
    </div>
    <div class="empty-state" id="exp-empty" style="display:none;padding:40px 20px">
      <div class="icon">📋</div>
      <p>Sin gastos registrados. Agrega el primero.</p>
    </div>
  </div>

  <!-- Summary by category -->
  <div class="card" id="exp-summary-card" style="display:none">
    <div class="card-header"><span class="card-title">Resumen por categoría</span></div>
    <div class="card-body" id="exp-summary-body" style="padding:16px 20px"></div>
  </div>
</div>
</div>

<!-- ══════════ MODALS ══════════ -->

<!-- PROJECT MODAL -->
<div class="modal-overlay" id="modal-project">
  <div class="modal">
    <h3 id="modal-project-title">Nuevo proyecto</h3>
    <div class="field-row">
      <div class="field-group">
        <label>Nombre del proyecto</label>
        <input type="text" id="p-name" placeholder="Ej. Brand Identity ACME">
      </div>
      <div class="field-group">
        <label>Cliente</label>
        <input type="text" id="p-client" placeholder="Nombre del cliente">
      </div>
    </div>
    <div class="field-row">
      <div class="field-group">
        <label>Tipo</label>
        <select id="p-type">
          <option value="iguala">Iguala mensual</option>
          <option value="oneshot">Proyecto único</option>
        </select>
      </div>
      <div class="field-group">
        <label id="p-income-label">Ingreso mensual</label>
        <div style="display:flex;gap:6px;align-items:stretch">
          <select id="p-currency" style="border:1.5px solid var(--paper-3);border-radius:var(--radius);padding:9px 10px;font-family:var(--sans);font-size:.85rem;background:#fff;flex-shrink:0" onchange="updateIncomePreview()">
            <option value="MXN">MXN $</option>
            <option value="USD">USD $</option>
          </select>
          <input type="number" id="p-income" placeholder="0" min="0" step="0.01"
            style="flex:1" oninput="updateIncomePreview()">
        </div>
        <div id="p-income-converted" style="font-size:.72rem;color:var(--ink-soft);margin-top:4px;display:none"></div>
      </div>
    </div>
    <div class="field-group" id="p-total-wrap" style="display:none">
      <label>Total del proyecto ($)</label>
      <input type="number" id="p-total" placeholder="0" min="0" step="1000">
    </div>
    <div class="field-group">
      <label>Color de identificación</label>
      <input type="color" id="p-color" value="#1a3a8f" style="height:38px;padding:4px;cursor:pointer">
    </div>

    <div class="separator"></div>
    <div style="font-size:.8rem;font-weight:700;margin-bottom:10px;color:var(--ink)">Asignación de equipo</div>
    <div style="font-size:.72rem;color:var(--ink-soft);margin-bottom:12px">Horas de <strong>producción</strong> por colaborador. Las juntas se registran por separado abajo.</div>
    <div id="p-assignments" class="assign-list"></div>
    <button class="btn-add outline" style="font-size:.78rem;padding:7px 14px;margin-top:10px;width:100%;justify-content:center" onclick="addAssignRow()">＋ Agregar miembro</button>

    <!-- Juntas row — inline with assignments -->
    <div style="border:1.5px solid rgba(180,83,9,.25);border-radius:6px;overflow:hidden;margin-top:10px;background:rgba(180,83,9,.03)">
      <div style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:rgba(180,83,9,.08);border-bottom:1px solid rgba(180,83,9,.15)">
        <span style="font-size:.78rem;font-weight:700;color:var(--amber)">⏱ Juntas / Reuniones</span>
        <span style="font-size:.68rem;color:var(--ink-soft);margin-left:auto">Tarifa JUNTAS** · $250/hr + overhead 1.5×</span>
      </div>
      <div style="display:grid;grid-template-columns:80px 1fr;gap:10px;padding:10px 12px;align-items:start">
        <div class="field-group" style="margin:0">
          <label>Horas</label>
          <input type="number" id="p-juntas-hrs" placeholder="0" min="0" step="0.5"
            oninput="updateJuntasPreview()" style="font-family:var(--mono)">
        </div>
        <div class="field-group" style="margin:0">
          <label>Descripción</label>
          <input type="text" id="p-juntas-desc" placeholder="Ej. Kick-off, revisiones…">
        </div>
      </div>
      <div style="padding:0 12px 10px">
        <div style="font-size:.68rem;font-weight:700;color:var(--ink-soft);margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em">¿A quiénes afecta su capacidad?</div>
        <div id="p-juntas-members" style="display:flex;flex-wrap:wrap;gap:6px"></div>
      </div>
      <div id="p-juntas-preview" style="font-size:.72rem;color:var(--amber);font-family:var(--mono);padding:6px 12px 10px;display:none"></div>
    </div>

    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('project')">Cancelar</button>
      <button class="btn-save" onclick="saveProject()">Guardar proyecto</button>
    </div>
  </div>
</div>

<!-- EMPLOYEE MODAL -->
<div class="modal-overlay" id="modal-employee">
  <div class="modal">
    <h3>Agregar colaborador</h3>
    <div class="field-row">
      <div class="field-group">
        <label>Nombre / Alias</label>
        <input type="text" id="e-name" placeholder="Ej. Santiago">
      </div>
      <div class="field-group">
        <label>Rol / Especialidad</label>
        <input type="text" id="e-role" placeholder="Ej. Diseñador Senior">
      </div>
    </div>
    <div class="field-group">
      <label>Honorarios mensuales ($)</label>
      <input type="number" id="e-salary" placeholder="0" min="0" step="1000">
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('employee')">Cancelar</button>
      <button class="btn-save" onclick="saveEmployee()">Guardar</button>
    </div>
  </div>
</div>

<!-- CORPORATE MODAL -->
<div class="modal-overlay" id="modal-corporate">
  <div class="modal">
    <h3>Empleado corporativo</h3>
    <div class="field-row">
      <div class="field-group">
        <label>Nombre</label>
        <input type="text" id="c-name" placeholder="Ej. Ana García">
      </div>
      <div class="field-group">
        <label>Rol</label>
        <input type="text" id="c-role" placeholder="Ej. Directora de Operaciones">
      </div>
    </div>
    <div class="field-group">
      <label>Costo mensual ($)</label>
      <input type="number" id="c-salary" placeholder="0" min="0" step="1000">
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('corporate')">Cancelar</button>
      <button class="btn-save" onclick="saveCorporate()">Guardar</button>
    </div>
  </div>
</div>

<!-- VENDOR MODAL -->
<div class="modal-overlay" id="modal-vendor">
  <div class="modal">
    <h3 id="vendor-modal-title">Agregar proveedor</h3>
    <div class="field-row">
      <div class="field-group">
        <label>Nombre / Descripción</label>
        <input type="text" id="v-name" placeholder="Ej. Fotógrafo freelance">
      </div>
      <div class="field-group">
        <label>Proyecto asignado</label>
        <select id="v-project"></select>
      </div>
    </div>
    <div class="field-row">
      <div class="field-group">
