// ── TOGGLE CARD ────────────────────────
function toggleCard(id) {
  const el = document.getElementById(id);
  if (el) el.classList.toggle('open');
}

// ── MODALS ─────────────────────────────
function openModal(type) {
  if (type === 'project') openProjectModal();
  else document.getElementById(`modal-${type}`).classList.add('open');
}
function closeModal(type) {
  document.getElementById(`modal-${type}`).classList.remove('open');
  if (type === 'project') { editingProjectId = null; clearProjectModal(); }
}

// Close on backdrop
document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) { const t = m.id.replace('modal-',''); closeModal(t); } });
});

// ── PROJECT MODAL ──────────────────────
let assignRows = [];

function openProjectModal(proj) {
  editingProjectId = proj ? proj.id : null;
  clearProjectModal();
  if (proj) {
    document.getElementById('modal-project-title').textContent = 'Editar proyecto';
    document.getElementById('p-name').value   = proj.name;
    document.getElementById('p-client').value = proj.client||'';
    document.getElementById('p-type').value   = proj.type;
    document.getElementById('p-income').value   = proj.income||'';
    document.getElementById('p-currency').value = proj.currency||'MXN';
    document.getElementById('p-total').value    = proj.total||'';
    document.getElementById('p-juntas-hrs').value  = proj.juntas?.hrs || '';
    document.getElementById('p-juntas-desc').value = proj.juntas?.desc || '';
    updateIncomePreview();
    renderJuntasMembersModal(proj.juntas?.members || []);
    document.getElementById('p-color').value  = proj.color;
    assignRows = (proj.assignments||[]).map(a => ({
      empId:     a.empId,
      hrs:       a.hrs || 0,
      breakdown: (a.breakdown||[]).map(b=>({...b})),
      _showBd:   false,
    }));
  } else {
    document.getElementById('modal-project-title').textContent = 'Nuevo proyecto';
    document.getElementById('p-color').value = COLORS[colorIdx % COLORS.length];
    colorIdx++;
    assignRows = [];
  }
  renderAssignRows();
  toggleTotalField();
  document.getElementById('modal-project').classList.add('open');
}

function clearProjectModal() {
  ['p-name','p-client','p-income','p-total'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('p-type').value     = 'iguala';
  document.getElementById('p-currency').value = 'MXN';
  document.getElementById('p-juntas-hrs').value  = '';
  document.getElementById('p-juntas-desc').value = '';
  const preview = document.getElementById('p-income-converted');
  if (preview) preview.style.display = 'none';
  const jp = document.getElementById('p-juntas-preview');
  if (jp) jp.style.display = 'none';
  assignRows = [];
  renderAssignRows();
  renderJuntasMembersModal([]);
}

document.getElementById('p-type').addEventListener('change', toggleTotalField);
function toggleTotalField() {
  const isOne = document.getElementById('p-type').value === 'oneshot';
  document.getElementById('p-total-wrap').style.display = isOne ? 'block' : 'none';
}

function updateIncomePreview() {
  const currency = document.getElementById('p-currency')?.value || 'MXN';
  const income   = parseFloat(document.getElementById('p-income').value) || 0;
  const preview  = document.getElementById('p-income-converted');
  if (!preview) return;
  if (currency === 'USD' && income > 0) {
    const mxn = income * getTC();
    preview.style.display = 'block';
    preview.textContent   = `≈ ${fmt(mxn)} MXN (TC: $${getTC().toFixed(2)})`;
  } else {
    preview.style.display = 'none';
  }
}

// ── JUNTAS MEMBERS MODAL ──────────────────────────────
let _juntasMembers = []; // empIds que participan en juntas

function renderJuntasMembersModal(selected=[]) {
  _juntasMembers = [...selected];
  const container = document.getElementById('p-juntas-members');
  if (!container) return;
  // Show all employees currently in assignRows + any already selected
  const relevantIds = new Set([
    ..._juntasMembers,
    ...assignRows.map(a => a.empId),
  ]);
  const allEmps = employees.filter(e => relevantIds.has(e.id));
  if (!allEmps.length) {
    container.innerHTML = '<span style="font-size:.75rem;color:var(--ink-soft)">Agrega colaboradores arriba primero</span>';
    return;
  }
  container.innerHTML = allEmps.map(e => {
    const active = _juntasMembers.includes(e.id);
    return `<button onclick="toggleJuntasMember(${e.id})" style="
      font-size:.75rem;padding:4px 12px;border-radius:20px;cursor:pointer;font-family:var(--sans);
      border:1.5px solid ${active?'var(--amber)':'var(--paper-3)'};
      background:${active?'rgba(180,83,9,.1)':'transparent'};
      color:${active?'var(--amber)':'var(--ink-soft)'};
      transition:all .15s">
      ${active?'⏱':''} ${e.name}
    </button>`;
  }).join('');
  updateJuntasPreview();
}

function toggleJuntasMember(empId) {
  const idx = _juntasMembers.indexOf(empId);
  if (idx >= 0) _juntasMembers.splice(idx, 1);
  else _juntasMembers.push(empId);
  renderJuntasMembersModal(_juntasMembers);
}

function updateJuntasPreview() {
  const hrs  = parseFloat(document.getElementById('p-juntas-hrs')?.value) || 0;
  const prev = document.getElementById('p-juntas-preview');
  if (!prev) return;
  if (hrs <= 0) { prev.style.display='none'; return; }
  const c = calcHrCost(hrs, JUNTAS_RATE);
  prev.style.display = 'block';
  prev.innerHTML = `${hrs}h × $${JUNTAS_RATE}/hr · C.Dir: ${fmt(c.costoDir)} · Overhead: ${fmt(c.overhead)} · <strong>C.Total: ${fmt(c.costoTotal)}</strong>`;
}

function addAssignRow() {
  if (!employees.length) { showToast('Primero agrega colaboradores en la sección Equipo'); return; }
  assignRows.push({ empId: employees[0].id, hrs: 0, breakdown: [], _showBd: false });
  renderAssignRows();
}

function addBreakdownRow(i) {
  if (!assignRows[i].breakdown) assignRows[i].breakdown = [];
  assignRows[i].breakdown.push({ desc: '', hrs: 0, type: 'produccion' });
  assignRows[i]._showBd = true;
  renderAssignRows();
}

function toggleBdType(i, j) {
  const b = assignRows[i].breakdown[j];
  b.type = b.type === 'junta' ? 'produccion' : 'junta';
  renderAssignRows();
}

function deleteBreakdownRow(i, j) {
  assignRows[i].breakdown.splice(j, 1);
  syncHrsFromBreakdown(i);
  renderAssignRows();
}

function updateBreakdownHrs(i, j, val) {
  assignRows[i].breakdown[j].hrs = parseFloat(val) || 0;
  syncHrsFromBreakdown(i);
  renderAssignRows();
}

function updateBreakdownDesc(i, j, val) {
  assignRows[i].breakdown[j].desc = val;
}

function syncHrsFromBreakdown(i) {
  const a = assignRows[i];
  if (a.breakdown && a.breakdown.length > 0) {
    a.hrs = a.breakdown.reduce((s, b) => s + (b.hrs || 0), 0);
  }
}

function toggleBreakdown(i) {
  assignRows[i]._showBd = !assignRows[i]._showBd;
  if (assignRows[i]._showBd && (!assignRows[i].breakdown || assignRows[i].breakdown.length === 0)) {
    assignRows[i].breakdown = [{ desc: '', hrs: assignRows[i].hrs || 0 }];
  }
  renderAssignRows();
}

function renderAssignRows() {
  const container = document.getElementById('p-assignments');
  if (!assignRows.length) {
    container.innerHTML = '<p style="font-size:.78rem;color:var(--ink-soft);padding:6px 0">Sin asignaciones.</p>';
    return;
  }
  // Refresh junta member chips whenever team changes
  renderJuntasMembersModal(_juntasMembers);
  container.innerHTML = assignRows.map((a, i) => {
    const hasBd   = a.breakdown && a.breakdown.length > 0;
    // if breakdown exists, hrs = sum of breakdown
    const dispHrs = hasBd ? a.breakdown.reduce((s,b)=>s+(b.hrs||0),0) : (a.hrs||0);
    const pct     = CAP > 0 ? (dispHrs / CAP * 100).toFixed(0) : 0;

    // total capacity for this employee across all projects (simulate)
    const existingHrs = (() => {
      let t = 0;
      projects.forEach(p => {
        if (editingProjectId && p.id === editingProjectId) return; // exclude self when editing
        const x = p.assignments.find(x => x.empId === a.empId);
        if (x) t += x.hrs || 0;
      });
      return t;
    })();
    const totalEmp    = existingHrs + dispHrs;
    const st          = capStatus(totalEmp);
    const badgeColor  = st.cls==='over'?'var(--accent-2)':st.cls==='warn'?'var(--gold)':'var(--green)';
    const bdLabel     = a._showBd ? '▲ Ocultar desglose' : (hasBd ? `▼ Ver desglose (${a.breakdown.length})` : '＋ Desglosar');

    // Breakdown rows HTML
    const bdHTML = a._showBd ? `
      <div class="breakdown-list">
        <div style="display:grid;grid-template-columns:1fr 80px 60px 24px;padding:2px 0 5px">
          <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-soft)">Actividad / Entregable</span>
          <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-soft);text-align:right">Hrs</span>
          <span style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-soft)">Tipo</span>
          <span></span>
        </div>
        ${(a.breakdown||[]).map((b, j) => `
          <div class="bd-row" style="grid-template-columns:1fr 80px 60px 24px">
            <input class="bd-input" type="text" value="${b.desc||''}" placeholder="Ej. Diseño de identidad…"
              oninput="updateBreakdownDesc(${i},${j},this.value)">
            <input class="bd-hrs" type="number" value="${b.hrs||''}" placeholder="0" min="0" step="0.5"
              oninput="updateBreakdownHrs(${i},${j},this.value)">
            <button onclick="toggleBdType(${i},${j})" title="Tipo de actividad"
              style="font-size:.62rem;padding:2px 5px;border-radius:4px;cursor:pointer;border:1px solid;font-family:var(--sans);white-space:nowrap;
                     background:${b.type==='junta'?'rgba(180,83,9,.1)':'rgba(26,58,143,.07)'};
                     color:${b.type==='junta'?'var(--amber)':'var(--accent)'};
                     border-color:${b.type==='junta'?'rgba(180,83,9,.3)':'rgba(26,58,143,.2)'}">
              ${b.type==='junta'?'⏱ Junta':'⚙ Prod'}
            </button>
            <button class="btn-del-bd" onclick="deleteBreakdownRow(${i},${j})">×</button>
          </div>`).join('')}
        <button class="toggle-bd" style="margin-top:5px;font-size:.68rem" onclick="addBreakdownRow(${i})">＋ Actividad</button>
        ${hasBd ? `<span style="font-size:.72rem;color:var(--ink-soft);margin-left:10px">Total: <strong>${dispHrs.toFixed(0)} hrs</strong></span>` : ''}
      </div>` : '';

    return `<div style="border:1.5px solid var(--paper-3);border-radius:6px;overflow:hidden;margin-bottom:6px">
      <div style="display:grid;grid-template-columns:1fr 80px 80px 36px 36px;align-items:center">
        <select class="assign-select" style="padding:8px 10px;border:none;background:transparent;font-family:var(--sans);font-size:.84rem;color:var(--ink);width:100%;appearance:none;cursor:pointer"
          onchange="assignRows[${i}].empId=parseInt(this.value);renderAssignRows()">
          ${employees.map(e => `<option value="${e.id}" ${e.id===a.empId?'selected':''}>${e.name}${e.role?' – '+e.role:''}</option>`).join('')}
        </select>
        <input class="assign-input" type="number" value="${hasBd ? dispHrs.toFixed(0) : (a.hrs||'')}"
          placeholder="hrs" min="0" max="200" step="0.5"
          ${hasBd ? 'readonly style="text-align:right;padding:8px 10px;background:var(--paper-2);color:var(--ink-soft);font-family:var(--mono);font-size:.82rem"' : 'style="text-align:right;padding:8px 10px;border:none;background:transparent;font-family:var(--mono);font-size:.82rem;color:var(--ink)"'}
          oninput="if(!${hasBd}){assignRows[${i}].hrs=parseFloat(this.value)||0;renderAssignRows()}">
        <div style="padding:8px 10px;font-size:.75rem;font-weight:700;color:${badgeColor};border-left:1px solid var(--paper-2)">${pct}% cap</div>
        <button class="btn-del-row" onclick="toggleBreakdown(${i})" title="Desglosar actividades" style="border-left:1px solid var(--paper-2);color:var(--accent);font-size:.7rem">⊞</button>
        <button class="btn-del-row" onclick="assignRows.splice(${i},1);renderAssignRows()" style="border-left:1px solid var(--paper-2)">×</button>
      </div>
      ${bdHTML}
    </div>`;
  }).join('');
}

function editProject(id) {
