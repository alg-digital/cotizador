<script>
// ══════════════════════════════════════════════════════
// DATA
// ══════════════════════════════════════════════════════
const TEAM = [
  { id:1,  name:"NC",         sueldo:90000 },
  { id:2,  name:"Jesus ALG",  sueldo:30000 },
  { id:3,  name:"Santiago",   sueldo:30000 },
  { id:4,  name:"INGRID",     sueldo:20000 },
  { id:7,  name:"Roberto",    sueldo:20000 },
  { id:8,  name:"Alfredo",    sueldo:20000 },
  { id:10, name:"Ana",        sueldo:20000 },
  { id:11, name:"JUNTAS**",   sueldo:30000 },
  { id:12, name:"Rocio",      sueldo:20000 },
  { id:13, name:"Kathia",     sueldo:17000 },
  { id:14, name:"Gamaliel",   sueldo:14000 },
  { id:15, name:"Com. MGR.",  sueldo:15000 },
  { id:16, name:"CARMINA",    sueldo:16500 },
  { id:17, name:"Copy 2",     sueldo:15000 },
  { id:18, name:"Isaac",      sueldo:14000 },
  { id:99, name:"Outsourcing",sueldo:0 },
];
const FACTOR = 1/20/6;   // horas efectivas por peso de sueldo
const getRate = id => {
  const m = TEAM.find(t => t.id === id);
  return m ? m.sueldo * FACTOR : 0;
};

let services = [];
let ppMonths = 1;
let svcCounter = 0;
let phaseCounter = 0;
let actCounter = 0;

// ══════════════════════════════════════════════════════
// STATE HELPERS
// ══════════════════════════════════════════════════════
function addService(name='') {
  const id = ++svcCounter;
  services.push({
    id, name: name || `Servicio ${id}`,
    phases: [],
    juntas: { type:'juntas', hrs:0, desc:'Meetings / Project Overhead' },
    outsourcing: [],
    showJuntas: false,
  });
  renderServices();
  addPhase(id, 'Fase 1A');
  refreshSidebar();
}

function addPhase(svcId, name='') {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  const id = ++phaseCounter;
  svc.phases.push({ id, name: name || `Fase ${svc.phases.length+1}`, activities: [] });
  renderServices();
  addActivity(svcId, id);
  refreshSidebar();
}

function addActivity(svcId, phaseId) {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  const ph = svc.phases.find(p => p.id === phaseId);
  if (!ph) return;
  const id = ++actCounter;
  ph.activities.push({ id, desc:'', memberId: 3, hrs: 0 });
  renderServices();
  refreshSidebar();
}

function deleteService(svcId) {
  services = services.filter(s => s.id !== svcId);
  renderServices();
  refreshSidebar();
}

function deletePhase(svcId, phaseId) {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  svc.phases = svc.phases.filter(p => p.id !== phaseId);
  renderServices();
  refreshSidebar();
}

function deleteActivity(svcId, phaseId, actId) {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  const ph = svc.phases.find(p => p.id === phaseId);
  if (!ph) return;
  ph.activities = ph.activities.filter(a => a.id !== actId);
  renderServices();
  refreshSidebar();
}

function toggleJuntas(svcId) {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  svc.showJuntas = !svc.showJuntas;
  if (!svc.showJuntas) svc.juntas.hrs = 0;
  renderServices(); refreshSidebar();
}

function updateJuntas(svcId, field, value) {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  if (field === 'hrs')  svc.juntas.hrs  = parseFloat(value) || 0;
  if (field === 'desc') svc.juntas.desc = value;
  refreshSidebar();
}

function addOutsourcing(svcId) {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  svc.outsourcing.push({ type:'outsourcing', id: ++actCounter, desc:'', costo:0, markup:0.25 });
  renderServices(); refreshSidebar();
}

function deleteOutsourcing(svcId, oId) {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  svc.outsourcing = svc.outsourcing.filter(o => o.id !== oId);
  renderServices(); refreshSidebar();
}

function updateOutsourcing(svcId, oId, field, value) {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  const o = svc.outsourcing.find(x => x.id === oId);
  if (!o) return;
  if (field === 'costo')  o.costo  = parseFloat(value) || 0;
  if (field === 'markup') o.markup = (parseFloat(value) || 25) / 100;
  if (field === 'desc')   o.desc   = value;
  refreshSidebar();
}

function updateField(svcId, phaseId, actId, field, value) {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  if (field === 'svcName') { svc.name = value; refreshSidebar(); return; }
  const ph = svc.phases.find(p => p.id === phaseId);
  if (!ph) return;
  if (field === 'phaseName') { ph.name = value; return; }
  const act = ph.activities.find(a => a.id === actId);
  if (!act) return;
  if (field === 'hrs') act.hrs = parseFloat(value) || 0;
  if (field === 'desc') act.desc = value;
  if (field === 'member') act.memberId = parseInt(value);
  refreshSidebar();
}

// ══════════════════════════════════════════════════════
// CALCULATIONS
// ══════════════════════════════════════════════════════
function getParams() {
  return {
    overhead: parseFloat(document.getElementById('p-overhead').value) || 1.5,
    util:     parseFloat(document.getElementById('p-util').value) || 0.5,
    dcto:     (parseFloat(document.getElementById('p-dcto').value) || 0) / 100,
    dcto2:    (parseFloat(document.getElementById('p-dcto2').value) || 0) / 100,
  };
}

function calcActivity(act, params) {
  // ── OUTSOURCING: input = costo proveedor $, markup fijo sobre costo ──
  // Fórmula Excel: G=D (costo directo=monto), H=G*E (overhead=costo*markup%)
  // J=G+H, K=J/(1-markup%), O=K*(1-dcto)
  if (act.type === 'outsourcing') {
    const costoDir   = act.costo || 0;
    const markup     = act.markup != null ? act.markup : 0.25;
    const overhead   = costoDir * markup;
    const costoTotal = costoDir + overhead;
    const precioLleno    = markup < 1 ? costoTotal / (1 - markup) : costoTotal;
    const precioDescuento = precioLleno * (1 - params.dcto);
    return { costoDir, overhead, costoTotal, precioLleno, precioDescuento };
  }
  // ── JUNTAS: horas × tarifa JUNTAS** (ID=11) × overhead normal × util normal ──
  // Fórmula Excel idéntica a actividad normal, pero siempre usa ID=11 (JUNTAS**)
  if (act.type === 'juntas') {
    const rate       = getRate(11);
    const costoDir   = (act.hrs || 0) * rate;
    const overhead   = costoDir * params.overhead;
    const costoTotal = costoDir + overhead;
    const precioLleno    = params.util > 0 ? costoTotal / (1 - params.util) : costoTotal * 2;
    const precioDescuento = precioLleno * (1 - params.dcto);
    return { costoDir, overhead, costoTotal, precioLleno, precioDescuento };
  }
  // ── ACTIVIDAD NORMAL ──
  const rate = getRate(act.memberId);
  const costoDir = (act.hrs || 0) * rate;
  const overhead = costoDir * params.overhead;
  const costoTotal = costoDir + overhead;
  const precioLleno = params.util > 0 ? costoTotal / (1 - params.util) : costoTotal * 2;
  const precioDescuento = precioLleno * (1 - params.dcto);
  return { costoDir, overhead, costoTotal, precioLleno, precioDescuento };
}

function calcService(svc, params) {
  let hrs=0, costoTotal=0, precioLleno=0, precioDescuento=0;
  svc.phases.forEach(ph => ph.activities.forEach(act => {
    const c = calcActivity(act, params);
    hrs += act.hrs || 0;
    costoTotal += c.costoTotal;
    precioLleno += c.precioLleno;
    precioDescuento += c.precioDescuento;
  }));
  // Juntas
  if (svc.juntas && svc.juntas.hrs > 0) {
    const c = calcActivity(svc.juntas, params);
    hrs += svc.juntas.hrs;
    costoTotal += c.costoTotal;
    precioLleno += c.precioLleno;
    precioDescuento += c.precioDescuento;
  }
  // Outsourcing (puede haber varios)
  (svc.outsourcing || []).forEach(o => {
    const c = calcActivity(o, params);
    costoTotal += c.costoTotal;
    precioLleno += c.precioLleno;
    precioDescuento += c.precioDescuento;
  });
  return { hrs, costoTotal, precioLleno, precioDescuento };
}

function calcTotal(params) {
  let hrs=0, costoTotal=0, precioLleno=0, precioDescuento=0;
  services.forEach(svc => {
    const c = calcService(svc, params);
    hrs += c.hrs;
    costoTotal += c.costoTotal;
    precioLleno += c.precioLleno;
    precioDescuento += c.precioDescuento;
  });
  const precioFinal = precioDescuento * (1 - params.dcto2);
  const utilidad = precioFinal - costoTotal;
  const pctUtil = precioFinal > 0 ? utilidad / precioFinal : 0;
  return { hrs, costoTotal, precioLleno, precioDescuento, precioFinal, utilidad, pctUtil };
}

function teamBreakdown(params) {
  const map = {};
  services.forEach(svc => {
    svc.phases.forEach(ph => ph.activities.forEach(act => {
      const m = TEAM.find(t => t.id === act.memberId);
      const name = m ? m.name : 'Desconocido';
      map[name] = (map[name] || 0) + (act.hrs || 0);
    }));
    if (svc.juntas && svc.juntas.hrs > 0)
      map['JUNTAS**'] = (map['JUNTAS**'] || 0) + svc.juntas.hrs;
  });
  return Object.entries(map).filter(([,h])=>h>0).sort((a,b)=>b[1]-a[1]);
}

// ══════════════════════════════════════════════════════
// FORMAT
// ══════════════════════════════════════════════════════
const fmt = n => '$' + n.toLocaleString('es-MX', {minimumFractionDigits:0, maximumFractionDigits:0});
const fmtPct = n => (n*100).toFixed(1) + '%';

// ══════════════════════════════════════════════════════
// RENDER SERVICES
// ══════════════════════════════════════════════════════
function buildTeamOptions(selected) {
  return TEAM.map(m =>
    `<option value="${m.id}" ${m.id===selected?'selected':''}>${m.name}</option>`
  ).join('');
}

function renderServices() {
  const container = document.getElementById('services-list');
  container.innerHTML = '';
  services.forEach(svc => {
    const params = getParams();
    const sc = calcService(svc, params);
    const hasVal = sc.precioDescuento > 0;

    const card = document.createElement('div');
    card.className = 'service-card';
    card.id = `svc-${svc.id}`;

    let phasesHTML = svc.phases.map(ph => {
      let actsHTML = ph.activities.map(act => `
        <div class="act-row" id="act-${act.id}">
          <textarea class="act-desc" rows="1" placeholder="Actividad / Entregable…"
            oninput="updateField(${svc.id},${ph.id},${act.id},'desc',this.value)"
          >${act.desc}</textarea>
          <select class="act-select"
            onchange="updateField(${svc.id},${ph.id},${act.id},'member',this.value)">
            ${buildTeamOptions(act.memberId)}
          </select>
          <input type="number" class="act-hrs" placeholder="0" min="0" step="0.5"
            value="${act.hrs||''}"
            oninput="updateField(${svc.id},${ph.id},${act.id},'hrs',this.value)">
          <button class="btn-del-act" onclick="deleteActivity(${svc.id},${ph.id},${act.id})" title="Eliminar">×</button>
        </div>
      `).join('');

      return `
        <div class="phase-block" id="phase-${ph.id}">
          <div class="phase-header">
            <span class="phase-tag">${ph.name.slice(0,6) || 'FASE'}</span>
            <input class="phase-name-input" type="text" value="${ph.name}"
              oninput="updateField(${svc.id},${ph.id},null,'phaseName',this.value)">
            <button class="btn-del-phase" onclick="deletePhase(${svc.id},${ph.id})" title="Eliminar fase">✕</button>
          </div>
          <div class="act-header-row">
            <span>Actividad / Entregable</span>
            <span>Responsable</span>
            <span>Hrs</span>
            <span></span>
          </div>
          <div class="activities-table">${actsHTML}</div>
          <div class="phase-footer">
            <button class="btn-add-act" onclick="addActivity(${svc.id},${ph.id})">＋ Actividad</button>
          </div>
        </div>`;
    }).join('');

    card.innerHTML = `
      <div class="service-header" onclick="toggleService(${svc.id}, event)">
        <div class="service-toggle">+</div>
        <input class="service-name-input" type="text" value="${svc.name}"
          placeholder="Nombre del servicio"
          oninput="updateField(${svc.id},null,null,'svcName',this.value)"
          onclick="event.stopPropagation()">
        <span class="service-price-tag ${hasVal?'has-value':''}">
          ${hasVal ? fmt(sc.precioDescuento) : '— sin horas'}
        </span>
      </div>
      <div class="service-body">
        ${phasesHTML}
        ${renderJuntasBlock(svc)}
        ${renderOutsourcingBlock(svc)}
        <div class="service-footer">
          <button class="btn-add-phase" onclick="addPhase(${svc.id})">＋ Fase</button>
          <button class="btn-special juntas-btn" onclick="toggleJuntas(${svc.id})">${svc.showJuntas ? '✕ Quitar Juntas' : '⏱ + Juntas'}</button>
          <button class="btn-special outsrc-btn" onclick="addOutsourcing(${svc.id})">📦 + Proveedor</button>
          <button class="btn-special" style="color:#7a7f94;border-color:rgba(120,120,140,.3)" onclick="saveServiceAsTemplate(${svc.id})">💾 Guardar template</button>
          <button class="btn-del-service" onclick="deleteService(${svc.id})">✕ Servicio</button>
        </div>
      </div>`;

    container.appendChild(card);

    // restore open state
    if (svc._open) card.classList.add('open');
  });
}

function renderJuntasBlock(svc) {
  if (!svc.showJuntas) return '';
  const j = svc.juntas;
  return `
    <div class="special-block juntas-block">
      <div class="special-header">
        <span class="special-tag juntas-tag">⏱ JUNTAS</span>
        <span class="special-label">Meetings / Project Overhead</span>
        <span class="special-note">Tarifa JUNTAS** · mismo cálculo que actividad normal</span>
      </div>
      <div class="act-header-row" style="grid-template-columns:1fr 140px 80px">
        <span>Descripción</span><span>Responsable</span><span>Hrs</span>
      </div>
      <div class="act-row" style="grid-template-columns:1fr 140px 80px">
        <textarea class="act-desc" rows="1" placeholder="Ej. Kick-off, revisiones, presentaciones…"
          oninput="updateJuntas(${svc.id},'desc',this.value)">${j.desc}</textarea>
        <div class="special-fixed-cell">JUNTAS**</div>
        <input type="number" class="act-hrs" placeholder="0" min="0" step="0.5"
          value="${j.hrs || ''}" oninput="updateJuntas(${svc.id},'hrs',this.value)">
      </div>
    </div>`;
}

function renderOutsourcingBlock(svc) {
  if (!svc.outsourcing || svc.outsourcing.length === 0) return '';
  const rows = svc.outsourcing.map(o => `
    <div class="act-row outsrc-row">
      <textarea class="act-desc" rows="1" placeholder="Nombre del proveedor / descripción…"
        oninput="updateOutsourcing(${svc.id},${o.id},'desc',this.value)">${o.desc}</textarea>
      <div class="outsrc-field">
        <span class="outsrc-label">Costo proveedor ($)</span>
        <input type="number" class="act-hrs" placeholder="0" min="0" step="100"
          value="${o.costo || ''}" oninput="updateOutsourcing(${svc.id},${o.id},'costo',this.value)" style="text-align:right">
      </div>
      <div class="outsrc-field" style="flex-direction:row;align-items:center;gap:4px">
        <span class="outsrc-label" style="width:auto;white-space:nowrap">Markup</span>
        <input type="number" class="act-hrs" placeholder="25" min="0" max="100" step="1"
          value="${Math.round((o.markup||0.25)*100)}"
          oninput="updateOutsourcing(${svc.id},${o.id},'markup',this.value)"
          style="width:44px;text-align:right">
        <span class="outsrc-label" style="width:auto">%</span>
      </div>
      <button class="btn-del-act" onclick="deleteOutsourcing(${svc.id},${o.id})">×</button>
    </div>`).join('');

  return `
    <div class="special-block outsrc-block">
      <div class="special-header">
        <span class="special-tag outsrc-tag">📦 PROVEEDOR</span>
        <span class="special-label">Outsourcing / Proveedores</span>
        <span class="special-note">Costo en $ · markup sobre costo · sin overhead ALG</span>
      </div>
      <div class="act-header-row outsrc-row-hdr">
        <span>Proveedor / Descripción</span><span>Costo ($)</span><span>Markup</span><span></span>
      </div>
      ${rows}
    </div>`;
}

function toggleService(svcId, e) {
  if (e.target.tagName === 'INPUT') return;
  const card = document.getElementById(`svc-${svcId}`);
  const svc = services.find(s => s.id === svcId);
  svc._open = !svc._open;
  card.classList.toggle('open', svc._open);
}

