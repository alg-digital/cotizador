function _doExportCliente(cotNum) {
  const params   = getParams();
  const tot      = calcTotal(params);
  const cliente  = document.getElementById('f-cliente').value  || 'Cliente';
  const proyecto = document.getElementById('f-proyecto').value || 'Proyecto';
  const prep     = document.getElementById('f-prep').value     || '';
  const rawFecha = document.getElementById('f-fecha').value;
  const rawValid = document.getElementById('f-validez').value;

  const fmtDate = iso => {
    if (!iso) return '—';
    const [y,m,d] = iso.split('-');
    const meses = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
    return `${parseInt(d)} ${meses[parseInt(m)-1]} ${y}`;
  };

  const iva      = tot.precioFinal * 0.16;
  const conIva   = tot.precioFinal + iva;
  const mes      = ppMonths > 0 ? tot.precioFinal / ppMonths : tot.precioFinal;
  const mesIva   = mes * 1.16;

  // Descuento pago único (5%)
  const DISC_UNICO = 0.05;
  const pagoUnico  = conIva * (1 - DISC_UNICO);

  // Fechas de pago (aprox: hoy + n*30 días)
  const today = rawFecha ? new Date(rawFecha + 'T12:00:00') : new Date();
  const schedDates = Array.from({length: ppMonths}, (_, i) => {
    const d = new Date(today);
    d.setDate(d.getDate() + i * 30);
    return fmtDate(d.toISOString().slice(0,10));
  });

  // ── Construir bloques de servicios ──
  let serviciosHTML = '';
  services.forEach((svc, sIdx) => {
    const sc = calcService(svc, params);

    let rowsHTML = '';
    svc.phases.forEach(ph => {
      ph.activities.forEach((act, i) => {
        rowsHTML += `
