function getSelectedServicio() {
  const d   = _importData;
  const sel = document.getElementById('import-svc-select');
  if (!sel || d.servicios.length === 1) return d.servicios[0];
  const val = sel.value;
  if (val === 'all') {
    // Merge all services into one virtual service
    const merged = { nombre: d.meta.proyecto, hrsTotal: 0, costoAlg: 0, precioLleno: 0, colaboradores: [], outsourcing: [] };
    d.servicios.forEach(s => {
      merged.hrsTotal    += s.hrsTotal;
      merged.costoAlg    += s.costoAlg;
      merged.precioLleno += s.precioLleno;
      merged.outsourcing  = merged.outsourcing.concat(s.outsourcing || []);
      // Merge collaborators
      s.colaboradores.forEach(c => {
        const ex = merged.colaboradores.find(x => x.name === c.name);
        if (ex) {
          ex.hrs        += c.hrs;
          ex.costoAlg   += c.costoAlg;
          ex.precioLleno+= c.precioLleno;
          ex.actividades = ex.actividades.concat(c.actividades || []);
        } else {
          merged.colaboradores.push({...c, actividades: [...(c.actividades||[])]});
        }
      });
    });
    return merged;
  }
  return d.servicios[parseInt(val)];
}

function renderImportMapping() {
  const svc = getSelectedServicio();
  _importMapping = {};

  // Auto-map
  svc.colaboradores.forEach(c => {
    if (c.name === 'JUNTAS**') {
      // Distribute juntas across employees in service
      _importMapping[c.name] = '__juntas__';
    } else {
      const match = fuzzyMatch(c.name, employees);
      _importMapping[c.name] = match ? match.id : null;
    }
  });

  // Render mapping rows
  const container = document.getElementById('import-mapping');
  container.innerHTML = svc.colaboradores.map(c => {
    const mapped  = _importMapping[c.name];
    const isJunta = c.name === 'JUNTAS**';
    const matchEmp = mapped && !isJunta ? employees.find(e => e.id === mapped) : null;
    const confidence = matchEmp ? '✓ Auto' : (isJunta ? '⏱' : '⚠ Sin match');
    const confColor  = matchEmp ? 'var(--green)' : isJunta ? 'var(--amber)' : 'var(--accent-2)';

    return `<div style="display:grid;grid-template-columns:140px 1fr 100px 80px;gap:0;border:1.5px solid var(--paper-3);border-radius:6px;overflow:hidden;align-items:center">
