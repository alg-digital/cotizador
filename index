function confirmImportCotizacion() {
  const d   = _importData;
  const svc = getSelectedServicio();
  if (!d || !svc) return;

  const COLORS_DASH = ['#1a3a8f','#c8972a','#e8312a','#1a6b3c','#b45309','#6d28d9','#0e7490','#9d174d'];
  const newProjId   = uid();
  const color       = COLORS_DASH[projects.length % COLORS_DASH.length];

  // Build assignments from mapping
  const assignments = [];
  svc.colaboradores.forEach(c => {
    if (c.name === 'JUNTAS**') return; // handle separately below
    const empId = _importMapping[c.name];
    if (!empId) return; // unmapped

    // Build breakdown from actividades
    const breakdown = (c.actividades || []).map(a => ({
      desc:        a.desc || '',
      hrs:         a.hrs  || 0,
      type:        a.tipo === 'junta' ? 'junta' : 'produccion',
      costoAlg:    a.costoAlg    || 0,
      precioLleno: a.precioLleno || 0,
    }));

    assignments.push({
      empId,
      hrs:         c.hrs || 0,
      costoAlg:    c.costoAlg    || 0,   // reference from cotizador
      precioLleno: c.precioLleno || 0,   // reference from cotizador
      breakdown,
    });
  });

  // JUNTAS**: bloque separado del proyecto, afecta a todos los asignados
  const juntasCollab = svc.colaboradores.find(c => c.name === 'JUNTAS**');
  const juntasBlock = juntasCollab && juntasCollab.hrs > 0 ? {
    hrs:     juntasCollab.hrs,
    desc:    juntasCollab.actividades?.[0]?.desc || 'Meetings / Project Overhead',
    members: assignments.map(a => a.empId), // todos los del proyecto
  } : { hrs: 0, desc: '', members: [] };

  // Create vendors from outsourcing
  (svc.outsourcing || []).forEach(o => {
    vendors.push({
      id:        uid(),
      name:      o.desc || 'Outsourcing',
      projectId: newProjId,
      cost:      o.costo || 0,
      charge:    o.precioLleno || 0,
    });
  });

  // Create project
  projects.push({
    id:          newProjId,
    name:        svc.nombre || d.meta.proyecto,
    client:      d.meta.cliente,
    type:        'oneshot',
    income:      svc.precioLleno,
    currency:    'MXN',
    total:       svc.precioLleno,
    color,
    juntas:      juntasBlock,
    assignments,
    _fromCotizador: true,
    _cotizadorRef: {
      costoAlg:    svc.costoAlg,
      precioLleno: svc.precioLleno,
      overhead:    d.params.overhead,
      utilidad:    d.params.utilidad,
    },
  });

  closeModal('import-cot');
  _importData = null;

  // Switch to projects tab
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-projects').classList.add('active');
  document.querySelectorAll('header nav button').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('header nav button')[1].classList.add('active');

  renderAll();

  // Open the new project card
  setTimeout(() => {
    const card = document.getElementById(`proj-card-${newProjId}`);
    if (card) {
      card.classList.add('open');
      card.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, 120);

  showToast(`Proyecto "${svc.nombre}" importado al Dashboard ✓`);
}

