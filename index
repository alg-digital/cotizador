// ── Import from Cotizador JSON ────────────────────────
function importPendingQuote(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      if (data._version !== 'alg-cotizador-v1') throw new Error('Formato no reconocido');

      data.servicios.forEach(svc => {
        // Map collaborators
        const assignments = [];
        svc.colaboradores.forEach(c => {
          if (c.name === 'JUNTAS**') return;
          const match = fuzzyMatch(c.name, employees);
          if (match && c.hrs > 0) assignments.push({ empId: match.id, hrs: c.hrs });
        });

        pendingQuotes.push({
          id:          uid(),
          name:        svc.nombre || data.meta.proyecto,
          client:      data.meta.cliente,
          income:      svc.precioLleno,
          prob:        60,
          assignments,
          scenA:       true,
          scenB:       false,
          _fromCot:    true,
        });
      });

      if (!_projPanelOpen) { _projPanelOpen = true; document.getElementById('proj-panel').classList.add('open'); }
      renderProjectionPanel();
      showToast(`${data.servicios.length} cotización(es) importada(s) a proyecciones ✓`);
    } catch(err) {
      showToast('Error al leer el archivo: ' + err.message);
    }
    event.target.value = '';
  };
  reader.readAsText(file);
}

