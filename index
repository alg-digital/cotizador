// ── VENDORS VIEW ───────────────────────
let _vendorFilter = 'all';
function filterVendors(f, btn) {
  _vendorFilter = f;
  document.querySelectorAll('#vendor-filters button').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderVendors();
}

function renderVendors() {
  const list    = document.getElementById('vendors-list');
  const empty   = document.getElementById('vendor-empty');
  const sumCard = document.getElementById('vendor-summary-card');
  const count   = document.getElementById('vendor-count');
  count.textContent = vendors.length ? `(${vendors.length})` : '';

  const filtered = vendors.filter(v => {
    if (_vendorFilter === 'active')   return isVendorActive(v);
    if (_vendorFilter === 'inactive') return !isVendorActive(v);
    return true;
  });

  if (!vendors.length) {
    list.innerHTML = ''; empty.style.display = 'block'; sumCard.style.display = 'none'; return;
  }
  empty.style.display = 'none'; sumCard.style.display = 'block';

  list.innerHTML = filtered.map(v => {
    const proj    = projects.find(p => p.id === v.projectId);
    const active  = isVendorActive(v);
    const margin  = (v.charge||0) - (v.cost||0);
    const modeLabel = {auto:'🔄 Auto', yes:'✅ Forzar activo', no:'⏸ Inactivo'}[v.activeMode||'auto'];
    const activeBadge = active
      ? '<span class="badge ok" style="font-size:.65rem">✅ Activo</span>'
      : '<span class="badge idle" style="font-size:.65rem">⏸ Inactivo</span>';

    return `<div class="list-card" style="margin-bottom:10px">
      <div class="list-card-header" style="cursor:default">
        <div style="display:flex;align-items:center;gap:10px;flex:1;flex-wrap:wrap">
          <span style="font-size:.95rem;font-weight:700">${v.name||'Sin nombre'}</span>
          ${proj ? `<span style="display:flex;align-items:center;gap:5px;font-size:.78rem;color:var(--ink-soft)"><span class="dot" style="background:${proj.color}"></span>${proj.name}</span>` : '<span style="font-size:.78rem;color:var(--ink-soft)">Sin proyecto</span>'}
          ${activeBadge}
          <span style="font-size:.72rem;color:var(--ink-soft)">${modeLabel}</span>
        </div>
        <div style="display:flex;align-items:center;gap:16px;flex-shrink:0">
          <div style="text-align:right">
            <div style="font-family:var(--mono);font-size:.82rem;color:var(--accent-2)">Costo: ${fmt(v.cost||0)}</div>
            <div style="font-family:var(--mono);font-size:.82rem;color:var(--green)">Cobro: ${fmt(v.charge||0)}</div>
            <div style="font-family:var(--mono);font-size:.75rem;color:${margin>=0?'var(--green)':'var(--accent-2)'};font-weight:600">Margen: ${fmt(margin)}</div>
          </div>
          <button class="btn-add outline" style="font-size:.72rem;padding:5px 12px" onclick="editVendor(${v.id})">✏ Editar</button>
          <button class="btn-add outline" style="font-size:.72rem;padding:5px 12px;color:var(--accent-2);border-color:rgba(232,49,42,.3)" onclick="deleteVendor(${v.id})">✕</button>
        </div>
      </div>
    </div>`;
  }).join('');

  // Summary — only active vendors
  const activeVendors  = vendors.filter(isVendorActive);
  const totalCostA     = activeVendors.reduce((s,v) => s + (v.cost||0), 0);
  const totalChargeA   = activeVendors.reduce((s,v) => s + (v.charge||0), 0);
  const totalMarginA   = totalChargeA - totalCostA;
  const inactiveCount  = vendors.filter(v=>!isVendorActive(v)).length;

  document.getElementById('vendor-summary-body').innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px">
      <div>
        <div style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin-bottom:4px">Costo activos este mes</div>
        <div style="font-family:var(--mono);font-size:1.1rem;color:var(--accent-2)">${fmt(totalCostA)}</div>
        <div style="font-size:.7rem;color:var(--ink-soft);margin-top:2px">${activeVendors.length} activo(s)</div>
      </div>
      <div>
        <div style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin-bottom:4px">Cobro total a clientes</div>
        <div style="font-family:var(--mono);font-size:1.1rem;color:var(--green)">${fmt(totalChargeA)}</div>
      </div>
      <div>
        <div style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin-bottom:4px">Margen bruto</div>
        <div style="font-family:var(--mono);font-size:1.1rem;color:${totalMarginA>=0?'var(--green)':'var(--accent-2)'};font-weight:600">${fmt(totalMarginA)}</div>
      </div>
      <div>
        <div style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin-bottom:4px">Inactivos / en pausa</div>
        <div style="font-family:var(--mono);font-size:1.1rem;color:var(--ink-soft)">${inactiveCount}</div>
        <div style="font-size:.7rem;color:var(--ink-soft);margin-top:2px">no suman al mes</div>
      </div>
    </div>`;
}

