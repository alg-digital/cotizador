}

function saveProject() {
  const name = document.getElementById('p-name').value.trim();
  if (!name) { showToast('Escribe el nombre del proyecto'); return; }
  const proj = {
    id:          editingProjectId || uid(),
    name,
    client:      document.getElementById('p-client').value.trim(),
    type:        document.getElementById('p-type').value,
    income:      parseFloat(document.getElementById('p-income').value) || 0,
    currency:    document.getElementById('p-currency').value || 'MXN',
    total:       parseFloat(document.getElementById('p-total').value) || 0,
    juntas: {
      hrs:     parseFloat(document.getElementById('p-juntas-hrs').value) || 0,
      desc:    document.getElementById('p-juntas-desc').value.trim() || 'Meetings / Reuniones',
      members: _juntasMembers.slice(),
    },
    color:       document.getElementById('p-color').value,
    assignments: assignRows.map(a => {
      const hasBd = a.breakdown && a.breakdown.length > 0;
      const hrs   = hasBd ? a.breakdown.reduce((s,b)=>s+(b.hrs||0),0) : (a.hrs||0);
      return {
        empId:     a.empId,
        hrs,
        breakdown: hasBd ? a.breakdown.map(b=>({...b})) : [],
      };
    }),
  };
  if (editingProjectId) {
    const idx = projects.findIndex(p => p.id === editingProjectId);
    if (idx >= 0) projects[idx] = proj;
  } else {
    projects.push(proj);
  }
  closeModal('project');
  renderAll();
  showToast(`Proyecto "${name}" guardado ✓`);
  if (SUPABASE_READY) {
    const savedProj = editingProjectId
      ? projects.find(p => p.id === editingProjectId)
      : projects[projects.length-1];
    if (savedProj) sbSave('alg_projects', savedProj);
  }
}

function deleteProject(id) {
  const p = projects.find(x => x.id === id);
  if (!p || !confirm(`¿Eliminar el proyecto "${p.name}"?`)) return;
  projects = projects.filter(x => x.id !== id);
  vendors  = vendors.map(v => v.projectId === id ? {...v, projectId: null} : v);
  renderAll();
  if (SUPABASE_READY) sbDelete('alg_projects', id);
}

