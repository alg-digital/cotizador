function renderAlerts() {
  const alerts = [];

  // Over-capacity
  employees.forEach(emp => {
    const hrs = getEmployeeAssignedHrs(emp.id);
    if (hrs > CAP_MAX)   alerts.push({ type:'over', msg: `${emp.name} supera las ${CAP_MAX} hrs — ${hrs.toFixed(0)} hrs asignadas (sobrecargado).` });
    else if (hrs > CAP)  alerts.push({ type:'warn', msg: `${emp.name} está en zona de margen: ${hrs.toFixed(0)} hrs (entre ${CAP} y ${CAP_MAX}).` });
    else if (hrs === 0)  alerts.push({ type:'idle', msg: `${emp.name} no tiene horas asignadas este mes.` });
  });

  // Vendors with negative margin
  vendors.forEach(v => {
    if ((v.charge||0) < (v.cost||0)) {
      alerts.push({ type:'over', msg: `Proveedor "${v.name}": se cobra menos de lo que cuesta (costo ${fmt(v.cost)} vs cobro ${fmt(v.charge)}).` });
    }
  });

  // Income < total egresos (con IVA + gastos operativos)
  const income  = totalMonthlyIncome();
  const payroll = totalMonthlyPayroll(true);
  const vendorC = totalVendorCost();
  const expC    = totalExpenses();
  const totalEg = payroll + vendorC + expC;
  if (income > 0 && income < totalEg) {
    alerts.push({ type:'over', msg: `Ingresos (${fmt(income)}) menores que egresos totales (${fmt(totalEg)}).` });
  }

  const panel = document.getElementById('alerts-panel');
  if (!alerts.length) {
    panel.innerHTML = '<span style="font-size:.84rem;color:var(--green)">✓ Sin alertas. Todo en orden.</span>';
    return;
  }
  panel.innerHTML = alerts.map(a => `
    <div style="display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--paper-2)">
      <span style="font-size:1rem">${a.type==='over'?'🔴':'⚪'}</span>
      <span style="font-size:.84rem;color:var(--ink-mid)">${a.msg}</span>
    </div>
  `).join('');
}

