// Fuzzy name match: find best employee by name similarity
function fuzzyMatch(cotName, empList) {
  const norm = s => s.toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'')
    .replace(/[^a-z0-9]/g,' ').trim();
  const cn = norm(cotName);

  let best = null, bestScore = 0;
  empList.forEach(emp => {
    const en = norm(emp.name);
    // Check if either contains the other, or shares first word
    const cnWords = cn.split(' ');
    const enWords = en.split(' ');
    let score = 0;
    cnWords.forEach(cw => enWords.forEach(ew => {
      if (cw.length > 2 && ew.length > 2) {
        if (cw === ew) score += 3;
        else if (cw.startsWith(ew) || ew.startsWith(cw)) score += 2;
        else if (cw.includes(ew) || ew.includes(cw)) score += 1;
      }
    }));
    if (score > bestScore) { bestScore = score; best = emp; }
  });
  return bestScore > 0 ? best : null;
}

function importCotizacion(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      if (data._version !== 'alg-cotizador-v1') throw new Error('Formato no reconocido');
      _importData = data;
      openImportModal();
    } catch(err) {
      showToast('Error al leer el archivo: ' + err.message);
    }
    event.target.value = '';
  };
  reader.readAsText(file);
}

