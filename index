    </div>`).join('');

  // ── Lista de servicios en panel de pagos ──
  const svcListHTML = services.map((svc, i) => `
    <div style="display:flex;align-items:center;gap:8px;font-size:10px;color:#4a4d58;margin-bottom:4px;">
