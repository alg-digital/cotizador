// ── PAYROLL BREAKDOWN ──────────────────
function renderPayrollBreakdown() {
  const panel = document.getElementById('payroll-panel');
  if (!panel) return;

  // Combinados: aparecen en employees Y corporates — mostrar solo una vez
  const corpOnly  = corporates.filter(c => !c._combined);
  const combinados= corporates.filter(c =>  c._combined); // ya están en employees
  const allPeople = [
    ...employees.map(e => {
      const isCombined = combinados.some(c => c.id === e.id);
      return {...e, _cat: isCombined ? 'combinado' : 'facturable'};
    }),
    ...corpOnly.map(c => ({...c, _cat:'corporativo'})),
  ];

  const totalBase  = allPeople.reduce((s,p)=>s+(p.salary||0),0);
  const totalIva   = totalBase * IVA;
  const totalTotal = totalBase + totalIva;

  panel.innerHTML = allPeople.map(p => {
    const base  = p.salary || 0;
    const iva   = base * IVA;
    const total = base + iva;
    const catColor = p._cat==='facturable'?'var(--accent)':p._cat==='combinado'?'var(--amber)':'var(--ink-soft)';
    return `<div class="payroll-row">
      <div>
        <span class="payroll-name" style="font-weight:600">${p.name}</span>
        <span style="font-size:.68rem;background:var(--paper-2);color:${catColor};padding:1px 7px;border-radius:10px;margin-left:6px">${p._cat}</span>
      </div>
      <div style="display:flex;gap:14px;align-items:center">
        <span class="payroll-base">${fmt(base)}</span>
        <span class="payroll-iva">+${fmt(iva)}</span>
        <span class="payroll-total">${fmt(total)}</span>
      </div>
    </div>`;
  }).join('') + `
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;margin-top:4px;border-top:2px solid var(--ink)">
      <span style="font-size:.8rem;font-weight:700">TOTAL</span>
