// TABS
// ══════════════════════════════════════════════════════
function showTab(tab) {
  document.querySelectorAll('header nav button').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');

  document.getElementById('app-builder').style.display   = 'none';
  document.getElementById('app-breakdown').style.display = 'none';
  document.getElementById('app-templates').style.display = 'none';

  if (tab === 'builder') {
    document.getElementById('app-builder').style.display = '';
  } else if (tab === 'breakdown') {
    document.getElementById('app-breakdown').style.display = 'block';
    renderBreakdown();
  } else if (tab === 'templates') {
    document.getElementById('app-templates').style.display = 'block';
    renderTemplatesView();
  }
}

function renderBreakdown() {
  const params = getParams();
  const container = document.getElementById('breakdown-content');
  const tot = calcTotal(params);
  const pagoMes = ppMonths > 0 ? tot.precioFinal / ppMonths : tot.precioFinal;

  const tS   = `width:100%;border-collapse:collapse;margin-bottom:24px;font-size:.84rem;`;
  const thL  = `background:#1a2f5e;color:#fff;padding:8px 12px;text-align:left;font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;`;
  const thR  = `background:#1a2f5e;color:#fff;padding:8px 12px;text-align:right;font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;`;
  const tdL  = `padding:8px 12px;border-bottom:1px solid #e3e1d8;vertical-align:middle;`;
  const tdR  = `padding:8px 12px;border-bottom:1px solid #e3e1d8;text-align:right;font-family:'DM Mono',monospace;font-size:.82rem;`;

  let html = '';
  services.forEach(svc => {
    const sc = calcService(svc, params);
    const svcMes = ppMonths > 0 ? sc.precioDescuento / ppMonths : sc.precioDescuento;

    html += `<h3 style="font-family:'Monument Grotesk',sans-serif;font-weight:700;font-size:1rem;margin:0 0 6px;padding:10px 14px;background:#f8f7f4;border-left:4px solid #1a3a8f;">${svc.name}</h3>`;
    html += `<table style="${tS}"><thead><tr>
      <th style="${thL}">Fase</th>
      <th style="${thL}">Actividad / Entregable</th>
      <th style="${thR}">Precio s/Dcto</th>
      <th style="${thR}">Precio c/Dcto</th>
      <th style="${thR}">Pago / mes</th>
    </tr></thead><tbody>`;

    svc.phases.forEach(ph => {
      ph.activities.forEach((act, i) => {
        const c = calcActivity(act, params);
        const ap = ppMonths > 0 ? c.precioDescuento / ppMonths : c.precioDescuento;
        html += `<tr>
          <td style="${tdL};color:#2e5090;font-weight:600;white-space:nowrap">${i===0 ? ph.name : ''}</td>
          <td style="${tdL}">${act.desc || '—'}</td>
          <td style="${tdR}">${fmt(c.precioLleno)}</td>
          <td style="${tdR};color:#1a6b3c;font-weight:600">${fmt(c.precioDescuento)}</td>
          <td style="${tdR};color:#c8972a">${fmt(ap)}</td>
        </tr>`;
      });
    });

    if (svc.juntas && svc.juntas.hrs > 0) {
      const c = calcActivity(svc.juntas, params);
      const jp = ppMonths > 0 ? c.precioDescuento / ppMonths : c.precioDescuento;
      html += `<tr style="background:#f0f4ff">
        <td style="${tdL};color:#1a3a8f;font-style:italic;white-space:nowrap">Juntas</td>
        <td style="${tdL};font-style:italic">${svc.juntas.desc || 'Meetings / Project Overhead'}</td>
        <td style="${tdR}">${fmt(c.precioLleno)}</td>
        <td style="${tdR};color:#1a6b3c">${fmt(c.precioDescuento)}</td>
        <td style="${tdR};color:#c8972a">${fmt(jp)}</td>
      </tr>`;
    }
    (svc.outsourcing || []).forEach(o => {
      const c = calcActivity(o, params);
      const op = ppMonths > 0 ? c.precioDescuento / ppMonths : c.precioDescuento;
      html += `<tr style="background:#fff8f0">
        <td style="${tdL};color:#b45309;font-style:italic;white-space:nowrap">Proveedor</td>
        <td style="${tdL};font-style:italic">${o.desc || 'Outsourcing'} (${Math.round((o.markup||.25)*100)}% markup)</td>
        <td style="${tdR}">${fmt(c.precioLleno)}</td>
        <td style="${tdR};color:#1a6b3c">${fmt(c.precioDescuento)}</td>
        <td style="${tdR};color:#c8972a">${fmt(op)}</td>
      </tr>`;
    });

    html += `<tr style="background:#f2f2f2">
      <td colspan="2" style="${tdL};font-weight:700">SUBTOTAL ${svc.name}</td>
      <td style="${tdR};font-weight:700">${fmt(sc.precioLleno)}</td>
      <td style="${tdR};font-weight:700;color:#1a6b3c">${fmt(sc.precioDescuento)}</td>
      <td style="${tdR};font-weight:700;color:#c8972a">${fmt(svcMes)}</td>
    </tr></tbody></table>`;
  });

  // Totals + IVA
  const iva         = tot.precioFinal * 0.16;
  const totalConIva = tot.precioFinal + iva;
  const montoMes    = ppMonths > 0 ? tot.precioFinal / ppMonths : tot.precioFinal;
  const montoMesIva = montoMes * 1.16;

  html += `
    <div style="background:#1a2f5e;color:#fff;border-radius:8px;overflow:hidden;margin-top:4px">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-bottom:1px solid rgba(255,255,255,.12)">
        <div style="padding:16px 20px">
          <div style="font-size:.6rem;opacity:.5;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px">Precio s/descuento</div>
          <div style="font-family:'DM Mono',monospace;font-size:1rem">${fmt(tot.precioLleno)}</div>
        </div>
        <div style="padding:16px 20px;border-left:1px solid rgba(255,255,255,.1)">
          <div style="font-size:.6rem;opacity:.5;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px">Precio c/descuento</div>
          <div style="font-family:'DM Mono',monospace;font-size:1rem">${fmt(tot.precioFinal)}</div>
        </div>
        <div style="padding:16px 20px;border-left:1px solid rgba(255,255,255,.1)">
          <div style="font-size:.6rem;opacity:.5;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px">Pago mensual (${ppMonths} ${ppMonths===1?'pago':'meses'})</div>
          <div style="font-family:'DM Mono',monospace;font-size:1rem;color:#c8972a">${fmt(montoMes)}</div>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;background:rgba(0,0,0,.15)">
        <div style="padding:14px 20px">
          <div style="font-size:.6rem;opacity:.5;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px">IVA 16%</div>
          <div style="font-family:'DM Mono',monospace;font-size:.95rem;opacity:.8">${fmt(iva)}</div>
        </div>
        <div style="padding:14px 20px;border-left:1px solid rgba(255,255,255,.1)">
          <div style="font-size:.6rem;opacity:.5;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px">Total con IVA</div>
          <div style="font-family:'DM Mono',monospace;font-size:1.25rem;font-weight:700;color:#c8972a">${fmt(totalConIva)}</div>
        </div>
        <div style="padding:14px 20px;border-left:1px solid rgba(255,255,255,.1)">
          <div style="font-size:.6rem;opacity:.5;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px">Pago mensual + IVA</div>
          <div style="font-family:'DM Mono',monospace;font-size:1rem;color:#c8972a">${fmt(montoMesIva)}</div>
        </div>
      </div>
    </div>`;

  container.innerHTML = html;
}

