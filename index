          <div style="display:flex;align-items:center;gap:10px">
            <span style="font-family:var(--mono);font-size:.78rem;color:var(--ink-soft)">${h.toFixed(0)} hrs</span>
            <span class="badge ok">${pct}% cap.</span>
          </div>
        </div>
        ${bdDetail}
      </div>`;
    }).join('');

    const projVendors = vendors.filter(v => v.projectId === p.id);
    const vendorHTML = projVendors.length ? projVendors.map(v => `
      <div style="display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--paper-2)">
        <div style="display:flex;align-items:center;gap:8px">
          <span style="font-size:.9rem">📦</span>
          <span style="font-size:.82rem">${v.name}</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
          <span style="font-family:var(--mono);font-size:.78rem;color:var(--accent-2)">Costo: ${fmt(v.cost)}</span>
          <span style="font-family:var(--mono);font-size:.78rem;color:var(--green)">Cobro: ${fmt(v.charge)}</span>
        </div>
      </div>`).join('') : '';

    const teamCost = getProjectTeamCost(p);
    const teamCostIva  = teamCost * (1 + IVA);   // costo real pagado (con IVA)
    const vendorCostP  = projVendors.reduce((s,v) => s + (v.cost||0), 0);
    const totalCostP   = teamCostIva + vendorCostP;
    // Ingreso: en MXN + IVA cobrado al cliente
    const incomeMXN    = incomeInMXN(p);
    const incomeConIva = incomeMXN * (1 + IVA);
    const marginP      = incomeConIva - totalCostP;
    const marginPctP   = incomeConIva > 0 ? (marginP / incomeConIva * 100).toFixed(1) : '—';

    return `<div class="list-card" id="proj-card-${p.id}">
      <div class="list-card-header" onclick="toggleCard('proj-card-${p.id}')">
        <div class="toggle-icon">+</div>
        <div class="dot" style="background:${p.color}"></div>
        <span class="list-card-name">${p.name}</span>
        <span style="font-size:.78rem;color:var(--ink-soft);margin-right:8px">${p.client||''}</span>
        ${p._fromCotizador ? '<span class="badge ok" style="font-size:.62rem;flex-shrink:0">📋 Cotizador</span>' : ''}
        <span class="badge ${p.type==='iguala'?'fixed':'oneshot'}">${p.type==='iguala'?'Iguala':'Único'}</span>
        <span style="font-family:var(--mono);font-size:.85rem;font-weight:600;color:var(--green);margin-left:auto">
          ${p.currency==='USD' ? fmtUSD(p.income||0) : fmt(incomeInMXN(p))}${p.type==='iguala'?'/mes':''}
        </span>
        <div style="display:flex;gap:6px;margin-left:16px">
          <button class="btn-add outline" style="font-size:.72rem;padding:5px 12px" onclick="event.stopPropagation();editProject(${p.id})">✏ Editar</button>
          <button class="btn-add outline" style="font-size:.72rem;padding:5px 12px;color:var(--accent-2);border-color:rgba(232,49,42,.3)" onclick="event.stopPropagation();deleteProject(${p.id})">✕</button>
        </div>
      </div>
      <div class="list-card-body">
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:16px">
          <div>
            <div style="font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin-bottom:3px">${p.type==='iguala'?'Ingreso / mes':'Ingreso proyecto'}</div>
            <div style="font-family:var(--mono);font-size:.95rem;color:var(--green);font-weight:600">
              ${p.currency==='USD' ? fmtUSD(p.income||0) : fmt(incomeMXN)}
            </div>
            <div style="font-size:.68rem;color:var(--ink-soft)">
              + IVA: <span style="font-family:var(--mono);color:var(--green)">${fmt(incomeConIva)}</span>
              ${p.currency==='USD' ? `<br>≈ ${fmt(incomeMXN)} MXN` : ''}
            </div>
          </div>
          <div>
            <div style="font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin-bottom:3px">Costo equipo + IVA</div>
            <div style="font-family:var(--mono);font-size:.95rem;font-weight:600">${fmt(teamCostIva)}</div>
            <div style="font-size:.68rem;color:var(--ink-soft)">Base: <span style="font-family:var(--mono)">${fmt(teamCost)}</span></div>
          </div>
          <div>
            <div style="font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin-bottom:3px">Costo total</div>
            <div style="font-family:var(--mono);font-size:.95rem;font-weight:600">${fmt(totalCostP)}</div>
            ${vendorCostP > 0 ? `<div style="font-size:.68rem;color:var(--ink-soft)">Proveedores: <span style="font-family:var(--mono)">${fmt(vendorCostP)}</span></div>` : ''}
          </div>
          <div>
            <div style="font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin-bottom:3px">Margen bruto</div>
            <div style="font-family:var(--mono);font-size:.95rem;font-weight:600;color:${marginP>=0?'var(--green)':'var(--accent-2)'}">${fmt(marginP)}</div>
            <div style="font-size:.68rem;color:${marginP>=0?'var(--green)':'var(--accent-2)'}">${marginPctP !== '—' ? marginPctP+'%' : '—'}</div>
          </div>
        </div>
        ${p._fromCotizador && p._cotizadorRef ? `
          <div style="background:rgba(26,58,143,.06);border-radius:6px;padding:10px 14px;margin-bottom:14px;display:flex;gap:20px;flex-wrap:wrap">
            <div style="font-size:.62rem;color:var(--accent);font-weight:700;text-transform:uppercase;letter-spacing:.06em;width:100%;margin-bottom:4px">Referencia Cotizador</div>
            <div><div style="font-size:.62rem;color:var(--ink-soft)">Overhead</div><div style="font-family:var(--mono);font-size:.82rem">${p._cotizadorRef.overhead}×</div></div>
            <div><div style="font-size:.62rem;color:var(--ink-soft)">Utilidad</div><div style="font-family:var(--mono);font-size:.82rem">${(p._cotizadorRef.utilidad*100).toFixed(0)}%</div></div>
            <div><div style="font-size:.62rem;color:var(--ink-soft)">Costo ALG</div><div style="font-family:var(--mono);font-size:.82rem">${fmt(p._cotizadorRef.costoAlg)}</div></div>
            <div><div style="font-size:.62rem;color:var(--ink-soft)">Precio cotizado</div><div style="font-family:var(--mono);font-size:.82rem;font-weight:600;color:var(--accent)">${fmt(p._cotizadorRef.precioLleno)}</div></div>
          </div>` : ''}
        ${assignHTML ? `
          <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin-bottom:8px">Equipo asignado</div>
          ${assignHTML}
        ` : '<p style="font-size:.82rem;color:var(--ink-soft)">Sin miembros asignados.</p>'}
        ${p.juntas && p.juntas.hrs > 0 ? (() => {
          const jc = calcHrCost(p.juntas.hrs, JUNTAS_RATE);
          const mnames = (p.juntas.members||[]).map(mid => {
            const em = employees.find(e=>e.id===mid);
            return em ? em.name : '—';
          }).join(', ');
          return `<div style="display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--paper-2);background:rgba(180,83,9,.03)">
            <div style="display:flex;align-items:center;gap:8px">
              <div style="width:8px;height:8px;border-radius:50%;background:var(--amber);flex-shrink:0"></div>
              <div>
                <span style="font-size:.82rem;font-weight:600;color:var(--amber)">⏱ Juntas</span>
                <span style="font-size:.75rem;color:var(--ink-soft);margin-left:6px">${p.juntas.desc||'Meetings'}</span>
                ${mnames ? `<div style="font-size:.68rem;color:var(--ink-soft)">Afecta: ${mnames}</div>` : ''}
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:16px;flex-shrink:0">
              <span style="font-size:.72rem;color:var(--ink-soft)">C.Dir <span style="font-family:var(--mono)">${fmt(jc.costoDir)}</span></span>
              <span style="font-size:.72rem;color:var(--ink-soft)">Overhead <span style="font-family:var(--mono)">${fmt(jc.overhead)}</span></span>
              <span style="font-family:var(--mono);font-size:.82rem;font-weight:700;color:var(--amber)">${p.juntas.hrs} hrs · ${fmt(jc.costoTotal)}</span>
            </div>
          </div>`;
        })() : ''}
        ${vendorHTML ? `
          <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin:14px 0 8px">Proveedores</div>
          ${vendorHTML}
        ` : ''}
      </div>
    </div>`;
  }).join('');
}

