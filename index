let _editEmpId   = null;
let _editEmpCat  = null; // 'billable' | 'corporate'

function openEditEmployee(id, cat) {
  const person = cat === 'billable'
    ? employees.find(e => e.id === id)
    : corporates.find(c => c.id === id);
  if (!person) return;
  _editEmpId  = id;
  _editEmpCat = cat;

  document.getElementById('ee-name').value   = person.name || '';
  document.getElementById('ee-role').value   = person.role || '';
  document.getElementById('ee-salary').value = person.salary || '';

  // determine type
  let typeVal = 'billable';
  if (cat === 'corporate') typeVal = person._combined ? 'combined' : 'corporate';
  document.getElementById('ee-type').value = typeVal;

  updateEePreview();
  document.getElementById('modal-edit-employee').classList.add('open');
}

function updateEePreview() {
  const base = parseFloat(document.getElementById('ee-salary').value) || 0;
  const iva  = base * IVA;
  document.getElementById('ee-base-preview').textContent  = fmt(base);
  document.getElementById('ee-iva-preview').textContent   = fmt(iva);
  document.getElementById('ee-total-preview').textContent = fmt(base + iva);
}

document.getElementById('ee-salary').addEventListener('input', updateEePreview);

function saveEditEmployee() {
  if (_editEmpId === null) return;
  const name   = document.getElementById('ee-name').value.trim();
  const role   = document.getElementById('ee-role').value.trim();
  const salary = parseFloat(document.getElementById('ee-salary').value) || 0;
  const type   = document.getElementById('ee-type').value;

  if (!name) { showToast('Escribe el nombre'); return; }

  // Determine new categories
  const isBillable  = type === 'billable' || type === 'combined';
  const isCorporate = type === 'corporate' || type === 'combined';
  const isCombined  = type === 'combined';

  // Remove from both lists first
  employees  = employees.filter(e => e.id !== _editEmpId);
  corporates = corporates.filter(c => c.id !== _editEmpId);

  const base = { id: _editEmpId, name, role, salary, _combined: isCombined };

  if (isBillable)  employees.push({...base});
  if (isCorporate) corporates.push({...base, _combined: isCombined});

  closeModal('edit-employee');
  renderAll();
  showToast(`${name} actualizado ✓`);
  if (SUPABASE_READY) {
    const updEmp  = employees.find(e => e.id === _editEmpId);
    const updCorp = corporates.find(c => c.id === _editEmpId);
    if (updEmp)  sbSave('alg_employees',  updEmp);
    if (updCorp) sbSave('alg_corporates', updCorp);
  }
}

