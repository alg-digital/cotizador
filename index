function setActiveScenario(s) {
  _activeScenario = s;
  ['A','B','all'].forEach(x => {
    const btn = document.getElementById(`scen-tab-${x.toLowerCase()}`);
    if (btn) btn.classList.toggle('on', x === s);
  });
  renderProjectionPanel();
}

// Get quotes active in current scenario
function getActiveQuotes() {
  if (_activeScenario === 'all') return pendingQuotes;
  if (_activeScenario === 'A')   return pendingQuotes.filter(q => q.scenA);
  if (_activeScenario === 'B')   return pendingQuotes.filter(q => q.scenB);
  return [];
}

// Projected income = base income + active quotes (weighted by probability)
function projectedIncome(weighted=false) {
  const base = totalMonthlyIncomeBase();
  const extra = getActiveQuotes().reduce((s, q) => {
    const inc = q.income || 0;
    return s + (weighted ? inc * (q.prob/100) : inc);
  }, 0);
  return (base + extra) * (1 + IVA);
}

function projectedMargin(weighted=false) {
  const payroll = totalMonthlyPayroll(true);
  const vendors = totalVendorCost();
  const exps    = totalExpenses();
  return projectedIncome(weighted) - payroll - vendors - exps;
}

// Projected hours per employee
function projectedEmpHrs(empId) {
  const current = getEmployeeAssignedHrs(empId);
  const extra   = getActiveQuotes().reduce((s, q) => {
    const a = (q.assignments||[]).find(x => x.empId === empId);
    return s + (a ? (a.hrs||0) : 0);
  }, 0);
  return current + extra;
}

