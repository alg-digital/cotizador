function refreshSidebar() {
  const params = getParams();
  const tot = calcTotal(params);

  // Per-service list
  const svcList = document.getElementById('sb-services-list');
  svcList.innerHTML = services.map(svc => {
    const sc = calcService(svc, params);
    return `
      <div class="service-summary-item">
        <div class="ssi-name">${svc.name}</div>
        <div class="ssi-row">
          <span class="ssi-hrs">${sc.hrs.toFixed(1)} hrs</span>
          <span class="ssi-price">${fmt(sc.precioDescuento)}</span>
        </div>
      </div>`;
  }).join('') || '<div style="font-size:.75rem;color:rgba(255,255,255,.3);padding:8px 0">Sin servicios</div>';

  document.getElementById('sb-hrs').textContent = tot.hrs.toFixed(1) + ' hrs';
  document.getElementById('sb-costo').textContent = fmt(tot.costoTotal);
  document.getElementById('sb-precio-lleno').textContent = fmt(tot.precioLleno);
  document.getElementById('sb-final').textContent = fmt(tot.precioFinal);
  document.getElementById('sb-utilidad').textContent =
    `Utilidad: ${fmt(tot.utilidad)} · ${fmtPct(tot.pctUtil)}`;

  // Payment plan
  refreshPaymentPlan(tot.precioFinal);

  // Team breakdown
  const tb = teamBreakdown(params);
  document.getElementById('tb-list').innerHTML = tb.map(([name, hrs]) =>
    `<div class="tb-row"><span class="tb-name">${name}</span><span class="tb-hrs">${hrs.toFixed(1)} hrs</span></div>`
  ).join('') || '<div style="font-size:.75rem;color:rgba(255,255,255,.3);padding:4px 0">Sin asignaciones</div>';
}

