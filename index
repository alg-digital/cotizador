    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
      <div>
        <div style="font-size:.62rem;text-transform:uppercase;letter-spacing:.06em;color:var(--green);font-weight:700;margin-bottom:2px">Ingreso que entra al Dashboard</div>
        <div style="font-family:var(--mono);font-size:1.2rem;font-weight:700;color:var(--green)">${fmt(svc.precioLleno)}</div>
