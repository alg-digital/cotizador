const EXP_CATS = [
  { value:'suscripcion', label:'Suscripción', cls:'cat-suscripcion' },
  { value:'servicios',   label:'Servicios',   cls:'cat-servicios'   },
  { value:'renta',       label:'Renta',       cls:'cat-renta'       },
