  const margin    = income - payroll - vendorCost;
  const marginPct = income > 0 ? margin / income : 0;
  const totalHrs  = employees.reduce((s,e) => s + getEmployeeAssignedHrs(e.id), 0);
  const totalCap  = employees.length * CAP;
  const totalMax  = employees.length * CAP_MAX;
  const occPct    = totalMax > 0 ? totalHrs / totalMax : 0;

  const totalExp  = totalExpenses();
  const kpis = [
    {
      label: 'Ingresos del mes',
      val: fmt(income),
      cls: 'gold',
      sub: `${projects.length} proyecto(s) activo(s)`,
      barW: 1, barColor: 'var(--gold)'
    },
    {
      label: 'Nómina total + IVA',
      val: fmt(payroll),
      cls: '',
      sub: `${employees.length + corporates.length} colaboradores · IVA incluido`,
      barW: income > 0 ? Math.min(payroll/income,1) : 0, barColor: 'var(--ink-mid)'
    },
    {
      label: 'Gastos operativos',
      val: fmt(totalExp),
      cls: totalExp > 0 ? '' : 'green',
      sub: `${expenses.length} concepto(s) · ${expenses.filter(e=>e.recurrent).length} fijos`,
      barW: income > 0 ? Math.min(totalExp/income,1) : 0, barColor: 'var(--amber)'
    },
    {
      label: 'Margen neto',
      val: fmt(margin - totalExp),
      cls: (margin - totalExp) >= 0 ? 'green' : 'red',
      sub: `${income > 0 ? (((margin-totalExp)/income)*100).toFixed(1) : '0'}% del ingreso · vs todos los egresos`,
      barW: Math.max(0, income > 0 ? (margin-totalExp)/income : 0),
      barColor: (margin-totalExp) >= 0 ? 'var(--green)' : 'var(--accent-2)'
    }
  ];

  document.getElementById('kpi-row').innerHTML = kpis.map(k => `
    <div class="kpi-card">
      <div class="kpi-label">${k.label}</div>
      <div class="kpi-val ${k.cls}">${k.val}</div>
      <div class="kpi-sub">${k.sub}</div>
      <div class="kpi-bar"><div class="kpi-bar-fill" style="width:${Math.min(k.barW,1)*100}%;background:${k.barColor}"></div></div>
    </div>
  `).join('');
}

function renderCapacityPanel() {
  const panel = document.getElementById('capacity-panel');
  if (!employees.length) {
    panel.innerHTML = '<p style="font-size:.82rem;color:var(--ink-soft);padding:8px 0">Sin colaboradores registrados.</p>';
    return;
  }

  // Legend
  const legend = `<div style="display:flex;gap:16px;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--paper-2)">
    <div style="display:flex;align-items:center;gap:5px"><div style="width:10px;height:10px;border-radius:2px;background:var(--accent)"></div><span style="font-size:.68rem;color:var(--ink-soft)">≤ 120 hrs efectivas</span></div>
    <div style="display:flex;align-items:center;gap:5px"><div style="width:10px;height:10px;border-radius:2px;background:var(--gold)"></div><span style="font-size:.68rem;color:var(--ink-soft)">121–140 hrs (margen)</span></div>
    <div style="display:flex;align-items:center;gap:5px"><div style="width:10px;height:10px;border-radius:2px;background:var(--accent-2)"></div><span style="font-size:.68rem;color:var(--ink-soft)">> 140 hrs</span></div>
  </div>`;

  const rows = employees.map(emp => {
    const hrs = getEmployeeAssignedHrs(emp.id);
    const st  = capStatus(hrs);

    // Bar fill: pct of CAP_MAX (140)
    const fillPct     = Math.min(hrs, CAP_MAX) / CAP_MAX * 100;
    const overflowPct = hrs > CAP_MAX ? Math.min((hrs - CAP_MAX) / CAP_MAX * 100, 20) : 0;

    // Bar color up to 120: accent; 120-140: gold; over: red
    let barColor;
    if (hrs <= CAP)     barColor = 'var(--accent)';
    else if (hrs <= CAP_MAX) barColor = 'var(--gold)';
    else                barColor = 'var(--accent-2)';

    // Marker positions as % of bar width (CAP_MAX = 100%)
    const mark120 = (CAP / CAP_MAX * 100).toFixed(1);   // 85.7%
    const mark140 = '100%';

    const projectDots = projects
      .filter(p => p.assignments.find(a => a.empId === emp.id))
      .map(p => `<span class="dot" style="background:${p.color}" title="${p.name}"></span>`)
      .join('');

    const hrsColor = hrs > CAP_MAX ? 'var(--accent-2)' : hrs > CAP ? 'var(--gold)' : 'var(--ink)';

    return `<div class="cap-row">
      <span class="cap-name">${emp.name}</span>
      <div style="flex:1;position:relative;height:10px;background:var(--paper-3);border-radius:5px;overflow:visible">
        <!-- fill -->
        <div style="position:absolute;left:0;top:0;height:100%;width:${fillPct}%;background:${barColor};border-radius:5px;transition:width .4s"></div>
        <!-- overflow beyond 140 -->
        ${overflowPct > 0 ? `<div style="position:absolute;left:100%;top:0;height:100%;width:${overflowPct}%;background:var(--accent-2);border-radius:0 5px 5px 0;opacity:.7"></div>` : ''}
        <!-- marker 120 hrs -->
        <div style="position:absolute;left:${mark120}%;top:-3px;height:16px;width:2px;background:var(--ink-soft);border-radius:1px;opacity:.4" title="120 hrs"></div>
        <!-- marker 140 hrs -->
        <div style="position:absolute;left:calc(${mark140} - 2px);top:-3px;height:16px;width:2px;background:var(--ink);border-radius:1px;opacity:.25" title="140 hrs"></div>
      </div>
      <span style="font-family:var(--mono);font-size:.75rem;min-width:52px;text-align:right;color:${hrsColor};font-weight:${hrs>CAP?'600':'400'}">${hrs.toFixed(0)} hrs</span>
      <span style="font-size:.7rem;color:var(--ink-soft);min-width:36px;text-align:right">${(hrs/CAP*100).toFixed(0)}%</span>
      <div style="display:flex;gap:3px;flex-shrink:0;min-width:40px">${projectDots}</div>
    </div>`;
  }).join('');

  panel.innerHTML = legend + rows;
}

