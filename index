    <div class="totbox">
      <div class="trow" style="grid-template-columns:repeat(4,1fr)">
        <div class="tcell"><label>Costo total ALG</label><span>${fmt(tot.costoTotal)}</span></div>
        <div class="tcell"><label>Precio c/descuento</label><span>${fmt(tot.precioFinal)}</span></div>
        <div class="tcell"><label>Utilidad bruta</label><span style="color:#4ade80">${fmt(totUtil)}</span></div>
        <div class="tcell"><label>% Utilidad</label><span style="color:#4ade80">${totPct}%</span></div>
      </div>
      <div class="trow ivrow" style="grid-template-columns:repeat(3,1fr)">
        <div class="tcell"><label>IVA 16%</label><span style="opacity:.7">${fmt(iva)}</span></div>
        <div class="tcell big"><label>Total con IVA</label><span>${fmt(conIva)}</span></div>
        <div class="tcell"><label>Pago mensual (${ppMonths} ${ppMonths===1?'pago':'meses'})</label><span style="color:#c8972a">${fmt(mes)}</span></div>
      </div>
    </div>
    <div class="footer" style="color:#e8312a;font-weight:600">USO INTERNO — No compartir con el cliente.</div>
  </body></html>`;
  pdfOpen(html);
}

// ══════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════
document.getElementById('f-fecha').value = new Date().toISOString().split('T')[0];
const _validez = new Date(); _validez.setDate(_validez.getDate() + 30);
document.getElementById('f-validez').value = _validez.toISOString().split('T')[0];

// Pre-load 5 default services
['Brand Strategy','Brand Identity','Web','Estrategia Digital','Producción Audiovisual']
  .forEach(name => addService(name));

// Open first service
if (services.length) {
  services[0]._open = true;
  renderServices();
}
refreshSidebar();
// ══════════════════════════════════════════════════════
// TEMPLATES
// ══════════════════════════════════════════════════════
const LS_KEY = 'alg_templates_v1';
let _pendingSvcId = null;
let _tmplFilter   = 'all';

function getTemplates() {
  try { return JSON.parse(localStorage.getItem(LS_KEY) || '[]'); }
  catch { return []; }
}
function saveTemplates(arr) {
  localStorage.setItem(LS_KEY, JSON.stringify(arr));
}

// ── Open modal to name & level the template ──────────────
function saveServiceAsTemplate(svcId) {
  const svc = services.find(s => s.id === svcId);
  if (!svc) return;
  _pendingSvcId = svcId;
  document.getElementById('tmpl-name-input').value  = svc.name;
  document.getElementById('tmpl-notes-input').value = '';
  document.getElementById('tmpl-level-input').value = 'startup';
  const modal = document.getElementById('tmpl-modal');
  modal.style.display = 'flex';
  setTimeout(() => document.getElementById('tmpl-name-input').focus(), 50);
}

function closeTemplateModal() {
  document.getElementById('tmpl-modal').style.display = 'none';
  _pendingSvcId = null;
}

// Close modal on backdrop click
document.getElementById('tmpl-modal').addEventListener('click', e => {
  if (e.target === document.getElementById('tmpl-modal')) closeTemplateModal();
});

function confirmSaveTemplate() {
  if (_pendingSvcId === null) return;
  const svc   = services.find(s => s.id === _pendingSvcId);
  if (!svc) return;
  const name  = document.getElementById('tmpl-name-input').value.trim() || svc.name;
  const level = document.getElementById('tmpl-level-input').value;
  const notes = document.getElementById('tmpl-notes-input').value.trim();

  // Deep-clone the service, strip runtime IDs so it can be re-loaded cleanly
  const snapshot = JSON.parse(JSON.stringify({
    name:        name,
    level:       level,
    notes:       notes,
    savedAt:     new Date().toISOString(),
    serviceName: svc.name,
    phases:      svc.phases.map(ph => ({
      name: ph.name,
      activities: ph.activities.map(a => ({
        desc: a.desc, memberId: a.memberId, hrs: a.hrs
      }))
    })),
    showJuntas:  svc.showJuntas,
    juntas:      { desc: svc.juntas.desc, hrs: svc.juntas.hrs },
    outsourcing: (svc.outsourcing||[]).map(o => ({
      desc: o.desc, costo: o.costo, markup: o.markup
    })),
  }));

  const templates = getTemplates();
  templates.unshift(snapshot);
  saveTemplates(templates);
  closeTemplateModal();
  renderTemplatesView();

  // Brief toast
  showToast(`Template "${name}" guardado ✓`);
}

// ── Load template into cotizador ─────────────────────────
function loadTemplate(idx) {
  const templates = getTemplates();
  const t = templates[idx];
  if (!t) return;

  if (!confirm(`¿Agregar "${t.name}" (${levelLabel(t.level)}) a la cotización actual?`)) return;

  // Create new service from template
  const svcId = ++svcCounter;
  const newSvc = {
    id: svcId,
    name: t.serviceName || t.name,
    phases: [],
    juntas: { type:'juntas', hrs: t.juntas?.hrs||0, desc: t.juntas?.desc||'Meetings / Project Overhead' },
    outsourcing: [],
    showJuntas: t.showJuntas || false,
    _open: true,
  };

  t.phases.forEach(ph => {
    const phId = ++phaseCounter;
    const acts = (ph.activities||[]).map(a => ({
      id: ++actCounter, desc: a.desc, memberId: a.memberId, hrs: a.hrs
    }));
    newSvc.phases.push({ id: phId, name: ph.name, activities: acts });
  });

  (t.outsourcing||[]).forEach(o => {
    newSvc.outsourcing.push({ type:'outsourcing', id:++actCounter, desc:o.desc, costo:o.costo, markup:o.markup });
  });

  services.push(newSvc);
  renderServices();
  refreshSidebar();

  // Switch to builder
  document.querySelectorAll('header nav button').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('header nav button')[0].classList.add('active');
  document.getElementById('app-builder').style.display   = '';
  document.getElementById('app-breakdown').style.display = 'none';
  document.getElementById('app-templates').style.display = 'none';

  // Scroll to new service
  setTimeout(() => {
    const el = document.getElementById(`svc-${svcId}`);
    if (el) el.scrollIntoView({ behavior:'smooth', block:'center' });
  }, 100);

  showToast(`"${t.name}" añadido a la cotización ✓`);
}

function deleteTemplate(idx) {
  const templates = getTemplates();
  const t = templates[idx];
  if (!t || !confirm(`¿Eliminar el template "${t.name}"?`)) return;
  templates.splice(idx, 1);
  saveTemplates(templates);
  renderTemplatesView();
}

// ── Filter ───────────────────────────────────────────────
function filterTemplates(level) {
  _tmplFilter = level;
  document.querySelectorAll('.tmpl-filter').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  renderTemplatesView();
}

// ── Render the templates grid ─────────────────────────────
function levelLabel(level) {
  return { startup:'🌱 Startup', mediana:'🏢 Mediana', enterprise:'🏛 Enterprise' }[level] || level;
}
function levelClass(level) {
  return { startup:'level-startup', mediana:'level-mediana', enterprise:'level-enterprise' }[level] || '';
}

function renderTemplatesView() {
  const all       = getTemplates();
  const filtered  = _tmplFilter === 'all' ? all : all.filter(t => t.level === _tmplFilter);
  const grid      = document.getElementById('tmpl-grid');
  const empty     = document.getElementById('tmpl-empty');

  if (filtered.length === 0) {
    grid.innerHTML = '';
    grid.style.display = 'none';
    empty.style.display = 'block';
    empty.querySelector('div:last-child').textContent =
      all.length === 0
        ? 'Abre un servicio en el Constructor y haz clic en "💾 Guardar template"'
        : 'No hay templates para este nivel. Prueba con otro filtro.';
    return;
  }

  empty.style.display = 'none';
  grid.style.display  = 'grid';
  grid.className      = 'tmpl-grid';

  // Map actual index in `all` array for delete/load
  grid.innerHTML = filtered.map(t => {
    const realIdx = all.indexOf(t);
    const date    = t.savedAt ? new Date(t.savedAt).toLocaleDateString('es-MX') : '';
    const phaseNames = (t.phases||[]).map(p =>
      `<span class="tmpl-phase-tag">${p.name}</span>`
    ).join('');
    const totalHrs = (t.phases||[]).reduce((s,p) =>
      s + (p.activities||[]).reduce((a,x) => a + (x.hrs||0), 0)
    , 0) + (t.juntas?.hrs||0);
    const extras = [
      t.showJuntas && t.juntas?.hrs > 0 ? `⏱ Juntas: ${t.juntas.hrs} hrs` : '',
      (t.outsourcing||[]).length > 0 ? `📦 ${t.outsourcing.length} proveedor(es)` : ''
    ].filter(Boolean).join(' · ');

    return `
      <div class="tmpl-card">
        <div class="tmpl-card-top">
          <div class="tmpl-card-name">${t.name}</div>
          <span class="tmpl-level-badge ${levelClass(t.level)}">${levelLabel(t.level)}</span>
        </div>
        ${t.notes ? `<div class="tmpl-notes">${t.notes}</div>` : ''}
        <div class="tmpl-meta">${totalHrs.toFixed(1)} hrs estimadas · ${date}</div>
        ${extras ? `<div class="tmpl-meta" style="color:var(--ink-soft)">${extras}</div>` : ''}
        <div class="tmpl-phases">${phaseNames}</div>
        <div class="tmpl-actions">
          <button class="tmpl-btn-load" onclick="loadTemplate(${realIdx})">＋ Cargar en cotización</button>
          <button class="tmpl-btn-del"  onclick="deleteTemplate(${realIdx})">🗑</button>
        </div>
      </div>`;
  }).join('');
}

// ── Export / Import JSON file ─────────────────────────────
function exportTemplatesFile() {
  const templates = getTemplates();
  if (templates.length === 0) { showToast('No hay templates para exportar'); return; }
  const blob = new Blob([JSON.stringify(templates, null, 2)], {type:'application/json'});
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  a.download = `ALG_templates_${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  URL.revokeObjectURL(a.href);
}

function importTemplatesFile(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const imported = JSON.parse(e.target.result);
      if (!Array.isArray(imported)) throw new Error('Formato inválido');
      const existing  = getTemplates();
      const merged    = [...imported, ...existing];
      // Deduplicate by name+savedAt
      const seen = new Set();
      const deduped = merged.filter(t => {
        const key = t.name + '|' + t.savedAt;
        if (seen.has(key)) return false;
        seen.add(key); return true;
      });
      saveTemplates(deduped);
      renderTemplatesView();
      showToast(`${imported.length} template(s) importado(s) ✓`);
    } catch {
      showToast('Error al leer el archivo. ¿Es un JSON válido?');
    }
    event.target.value = '';
  };
  reader.readAsText(file);
}

// ── Toast notification ────────────────────────────────────
function showToast(msg) {
  let t = document.getElementById('alg-toast');
  if (!t) {
    t = document.createElement('div');
    t.id = 'alg-toast';
    t.style.cssText = `
      position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);
      background:#0f1117;color:#fff;padding:10px 20px;border-radius:30px;
      font-family:'Monument Grotesk',sans-serif;font-size:.85rem;
      opacity:0;transition:all .25s;z-index:9999;pointer-events:none;white-space:nowrap;
    `;
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.opacity = '1';
  t.style.transform = 'translateX(-50%) translateY(0)';
  clearTimeout(t._timer);
  t._timer = setTimeout(() => {
    t.style.opacity = '0';
    t.style.transform = 'translateX(-50%) translateY(20px)';
  }, 2800);
}

