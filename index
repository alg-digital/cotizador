function setVendorActiveMode(mode) {
  _vendorActiveMode = mode;
  const styles = {
    auto: { bg:'rgba(26,58,143,.1)', color:'var(--accent)', border:'var(--accent)' },
    yes:  { bg:'var(--green-bg)',    color:'var(--green)',  border:'var(--green)'  },
